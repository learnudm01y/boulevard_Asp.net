                        <td style="padding:10px 30px 0 30px;">
                            <table role="presentation" style="width:100%;border-collapse:collapse;border:0;border-spacing:0;">
                                <tr>
                                    <td style="padding:0 0 0 0;color:#153643;width:49%;text-align: left;">
                                        <a href="https://play.google.com/store/apps/details?id=com.royex.tahtaj">
                                            <img src="http://tahtaj.r-y-x.net/Content/Images/playstore.png" alt="" width="130"
                                                 style="height:auto;display:block;text-align:center;margin:auto 0 auto auto;" />
                                        </a>
                                    </td>
                                    <td style="padding:0 0;width:2%;">

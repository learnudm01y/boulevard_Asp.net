                                    <td style="width:100%;text-align:center;">
                                        <a href="http://tahtaj.com/api/v1/member/MemberActive?email=@Model.Email" style="font-size: 14px; font-weight: 500; padding:10px 30px 10px;border-radius:6px;color:#fff;width:100%;text-align: center;background-color: #302D86; overflow: hidden; text-decoration: none; ">
                                            Verify Now

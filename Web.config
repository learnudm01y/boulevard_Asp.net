<configuration>
  <configSections>
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <connectionStrings>
    <!--<add name="BoulevardDbContext" connectionString="Data Source=DESKTOP-NLDFSAL;Initial Catalog=BoulevardDb;user id=sa;password=123456;MultipleActiveResultSets=True;" providerName="System.Data.SqlClient" />-->
    <!-- Remote DB (original) -->
    <!-- <add name="BoulevardDbContext" connectionString="Data Source=109.203.124.192;Initial Catalog=BoulevardDb;user id=BoulevardDb-user;password=o50i!32qK;MultipleActiveResultSets=True;" providerName="System.Data.SqlClient" /> -->

    <!-- Local DB (SQL Express) - Integrated Security -->
    <add name="BoulevardDbContext" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=BoulevardDb;Integrated Security=True;MultipleActiveResultSets=True;" providerName="System.Data.SqlClient" />

    <!-- Alternative: SQL Express with SQL Authentication (uncomment and set credentials if needed)
    <add name="BoulevardDbContext" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=BoulevardDb;User ID=BoulevardDb-user;Password=yourPassword;MultipleActiveResultSets=True;" providerName="System.Data.SqlClient" />
    -->
  </connectionStrings>
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
  </system.web>

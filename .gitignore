# ================================================================
# Boulevard ASP.NET MVC — .gitignore
# ================================================================
# الهدف: رفع الكود المصدري فقط إلى GitHub ثم البناء على السيرفر
# عبر:  nuget restore  ثم  msbuild
# ================================================================


# ----------------------------------------------------------------
# 1. مجلدات البناء — تُعاد تلقائياً عند تنفيذ MSBuild
# ----------------------------------------------------------------
[Bb]in/
[Oo]bj/


# ----------------------------------------------------------------
# 2. ملفات Visual Studio / Rider الخاصة بالجهاز
# ----------------------------------------------------------------
.vs/
*.user
*.suo
*.userprefs
*.userosscache
*.sln.docstates
*.rsuser
.idea/


# ----------------------------------------------------------------
# 3. حزم NuGet — لا تُرفع (يستعيدها السيرفر عبر nuget restore)
#    المجلد packages\ موجود على مستوى أعلى من الـ repo لذا
#    الإدخال هنا احتياطي فقط
# ----------------------------------------------------------------
packages/
*.nupkg
!packages.config


# ----------------------------------------------------------------
# 4. ملفات السجلات (Log) — مولّدة بالتشغيل
#    يُدار الاستثناء عبر Log/.gitignore المحلي
# ----------------------------------------------------------------
# (راجع Log/.gitignore)


# ----------------------------------------------------------------
# 5. ملفات الرفع من المستخدمين / الوسائط الضخمة
#    كل مجلد رفع يحوي .gitignore محلياً يتجاهل كل شيء ما عدا .gitkeep
#    هذا يضمن تتبع بنية المجلدات دون تتبع الصور والفيديو والبيانات
# ----------------------------------------------------------------
# (راجع Content/Upload/.gitignore, Content/Salon/.gitignore … إلخ)


# ----------------------------------------------------------------
# 6. الملفات الثنائية الضخمة الموجودة في جذر المشروع
# ----------------------------------------------------------------
*.zip
*.rar
*.7z
*.gz
*.tar


# ----------------------------------------------------------------
# 7. مستندات Office غير مرتبطة بالكود المصدري
# ----------------------------------------------------------------
*.xlsx
*.xls
*.docx
*.doc
*.pdf


# ----------------------------------------------------------------
# 8. ملفات الـ debug symbols (اختياري — حجم كبير وتُعاد عند البناء)
# ----------------------------------------------------------------
*.pdb


# ----------------------------------------------------------------
# 9. نتائج الاختبارات وبيانات مؤقتة
# ----------------------------------------------------------------
TestResults/
*.trx
*.cache
*.tmp
[Tt]humbs.db
[Dd]esktop.ini
.DS_Store


# ----------------------------------------------------------------
# 10. ملفات IIS Express و publish
# ----------------------------------------------------------------
*.pubxml
*.pubxml.user
PublishScripts/
publish/

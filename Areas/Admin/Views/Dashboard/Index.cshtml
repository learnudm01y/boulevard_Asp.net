@model Boulevard.Areas.Admin.Data.DashboardViewModel
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@* Chartist is loaded by _Scripts.cshtml (local copy) - no CDN duplicate needed *@


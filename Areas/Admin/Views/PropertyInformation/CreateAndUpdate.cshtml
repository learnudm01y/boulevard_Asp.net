@model Boulevard.Models.PropertyInformation
@{
    ViewBag.Title = "Create Or Update";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm("CreateAndUpdate", "PropertyInformation", FormMethod.Post, new { enctype = "multipart/form-data", @id = "myForm" }))
{


    <!-- Container fluid  -->
    <!-- ============================================================== -->
    <div class="page-wrapper">
        <div class="container-fluid">
            <!-- ============================================================== -->
            <!-- Bread crumb and right sidebar toggle -->
            <!-- ============================================================== -->

            <div class="row page-titles">
                <div class="col-md-5 col-12 align-self-center">
                    <h3 class="text-themecolor mb-0">Property Information</h3>
                </div>
                <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                        <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_Property_Information")">Property Information</a></li>
                        @if (Model.CityId == 0)
                        {
                            <li class="breadcrumb-item active">Create Property Information</li>
                        }
                        else
                        {
                            <li class="breadcrumb-item active">Update Property Information</li>
                        }
                    </ol>
                </div>
            </div>
            <!-- ============================================================== -->
            <!-- End Bread crumb and right sidebar toggle -->
            <!-- ============================================================== -->
            <!--order list-->
            <form>
                <div class="card">
                    <div class="card-header">
                        <!--<h4 class="">General</h4>-->
                        Property Information Information
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <input type="hidden" name="PropertyInformationId" class="form-control" value="@Model.PropertyInformationId">
                            <input type="hidden" name="CreateDate" class="form-control" value="@Model.CreateDate">
                            <input type="hidden" name="CreateBy" class="form-control" value="@Model.CreateBy">
                            <input type="hidden" name="PropertyInfoKey" class="form-control" value="@Model.PropertyInfoKey">

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Property Type</label>
                                    <select name="Type" id="Type" class="form-control select-2" required>
                                        <option value="">Select Type</option>
                                        <option value="Apartment">Apartment</option>
                                        <option value="Vila">Vila</option>
                                        <option value="TownHouse">Town House</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Property Type (Arabic)</label>
                                    <select name="TypeAr" id="TypeAr" class="form-control select-2" required>
                                        <option value="">حدد النوع</option>
                                        <option value="شقة">شقة</option>
                                        <option value="فيلا">فيلا</option>
                                        <option value="تاون هاوس">تاون هاوس</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Purpose</label>
                                    <input type="text" name="Purpose" required class="form-control" value="@Model.Purpose">
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Purpose (Arabic)</label>
                                    <input type="text" name="PurposeAr" required dir="rtl" class="form-control" value="@Model.PurposeAr">
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Refference No</label>
                                    <input type="text" name="RefNo" required class="form-control" value="@Model.RefNo">
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Refference No (Arabic)</label>
                                    <input type="text" name="RefNoAr" required class="form-control" dir="rtl" value="@Model.RefNoAr">
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Furnishing</label>
                                    <select name="Furnishing" id="Furnishing" class="form-control select-2" required>
                                        <option value="">Select Furnishing</option>
                                        <option value="Furnished">Furnished</option>
                                        <option value="Unfurnished">Unfurnished</option>
                                        <option value="Partly Furnished">Partly Furnished</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Furnishing (Arabic)</label>
                                    <select name="FurnishingAr" id="FurnishingAr" class="form-control select-2" required>
                                        <option value="">اختر المفروشات</option>
                                        <option value="مفروشة">مفروشة</option>
                                        <option value="غير مفروش">غير مفروش</option>
                                        <option value="مفروشة جزئيا">مفروشة جزئيا</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Property WhatsApp No</label>
                                    <input type="text" name="PropertyWhatsAppNo" required class="form-control" value="@Model.PropertyWhatsAppNo">
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Property Phone No</label>
                                    <input type="text" name="PropertyPhoneNo" required class="form-control" value="@Model.PropertyPhoneNo">
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Property Email</label>
                                    <input type="text" name="PropertyEmail" required class="form-control" value="@Model.PropertyEmail">
                                </div>
                            </div>

                            @*<div class="col-md-4 col-sm-4">
            <div class="form-group">
                <label>Country Name</label>
                @Html.DropDownListFor(model => model.CountryId, (List<SelectListItem>)ViewBag.Country, new { @class = "form-control select-2", @id = "CountryId", @onchange = "CityLoad(@Model.CountryId)" })
            </div>
        </div>

        <div class="col-md-4 col-sm-4">
            <div class="form-group">
                <label>City Name</label>
                @Html.DropDownListFor(model => model.CityId, (List<SelectListItem>)ViewBag.City, new { @class = "form-control select-2", @id = "CityId" })
            </div>
        </div>*@

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <div class="form-group">
                                        <label>Country</label>
                                        @Html.DropDownListFor(model => model.CountryId, (List<SelectListItem>)ViewBag.Country, new { @class = "form-control select-2", @id = "CountryId", @onchange = "GetCity(this.value);" })
                                    </div>
                                </div>
                            </div>


                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <div class="form-group">
                                        <label>City</label>
                                        @Html.DropDownListFor(model => model.CityId, (List<SelectListItem>)ViewBag.City, new { @class = "form-control select-2", @id = "CityId" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Real State Type</label>
                                    @Html.DropDownListFor(model => model.ServiceTypeId, (List<SelectListItem>)ViewBag.ServiceType, new { @class = "form-control select-2", @id = "CountryId" })
                                </div>
                            </div>

                            @*<div class="col-md-4 col-sm-4">
            <div class="form-group">
                <label>Purpose</label>
                <input type="text" name="Purpose" required class="form-control" value="@Model.RefNo">
            </div>
        </div>*@

                            <div class="col-md-6 col-sm-6">
                                <div class="form-group">
                                    <label>Status</label>
                                    <div class="switch">
                                        <label>
                                            InActive
                                            @if (Model.Status == "Active")
                                            {
                                                <input type="checkbox" checked="checked" name="Status" value="Active"><span class="lever"></span>
                                            }
                                            else
                                            {
                                                <input type="checkbox" name="Status" value="Active"><span class="lever"></span>
                                            }
                                            <input name="Status" type="hidden" value="Deleted" />
                                            Active
                                        </label>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>

                    <div class="card-body">
                        <div class="col-12">
                            <div class="form-group">
                                <label for="Interiors">Interiors</label><br>
                                <textarea id="Interiors" name="Interiors" rows="5" cols="108" required>@Model.Interiors</textarea>
                            </div>
                        </div>
                        
                        <div class="col-12">
                            <div class="form-group">
                                <label for="Interiors">Interiors (Arabic)</label><br>
                                <textarea id="Interiors" name="InteriorsAr" rows="5" cols="108" dir="rtl" required>@Model.InteriorsAr</textarea>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-6">
                            <div class="form-group">
                                <label>Interiors Images</label>
                                <input type="file" name="interiorsImages" accept="image/png, image/jpeg" class="form-control dropify" multiple />
                            </div>
                        </div>
                        <div class="row">
                            @if (Model.InteriorsImages != null && Model.InteriorsImages.Count() > 0)
                            {
                                foreach (var image in Model.InteriorsImages)
                                {
                                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                                        <div class="image-holder rounded-lg overflow-hidden" style="cursor: pointer; padding-top:25px">
                                            <img src="@image.FileLocation" class="img-fluid" style="height: 150px;">
                                            <a onclick="DeleteImage(@image.ServiceTypeFileId)" class="remove-image"><i class="mdi mdi-close" style="color:red"></i> </a>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="col-12">
                            <div class="form-group">
                                <label for="Exteriors">Exteriors</label><br>
                                <textarea id="Exteriors" name="Exteriors" rows="5" cols="108" required>@Model.Exteriors</textarea>
                            </div>
                        </div>
                        
                        <div class="col-12">
                            <div class="form-group">
                                <label for="Exteriors">Exteriors (Arabic)</label><br>
                                <textarea id="Exteriors" name="ExteriorsAr" rows="5" cols="108" dir="rtl" required>@Model.ExteriorsAr</textarea>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-6">
                            <div class="form-group">
                                <label>Exteriors Images</label>
                                <input type="file" name="exteriorsImages" accept="image/png, image/jpeg" class="form-control dropify" multiple />
                            </div>
                        </div>
                        <div class="row">
                            @if (Model.ExteriorsImages != null && Model.ExteriorsImages.Count() > 0)
                            {
                                foreach (var image in Model.ExteriorsImages)
                                {
                                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                                        <div class="image-holder rounded-lg overflow-hidden" style="cursor: pointer; padding-top:25px">
                                            <img src="@image.FileLocation" class="img-fluid" style="height: 150px;">
                                            <a onclick="DeleteImage(@image.ServiceTypeFileId)" class="remove-image"><i class="mdi mdi-close" style="color:red"></i> </a>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="form-group mb-0 text-right">
                            @if (Model.PropertyInformationId > 0)
                            {
                                <button type="submit" class="btn btn-warning waves-effect waves-light" id="submit-btn">Reset</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-success waves-effect waves-light" id="submit-btn">Save</button>
                            }
                            <a href="@Url.RouteUrl("Admin_Property_Information")" class="btn btn-dark waves-effect waves-light">
                                Close
                            </a>
                        </div>
                    </div>

                </div>
            </form>
            <!-- ============================================================== -->
        </div>
    </div>
    <!-- ============================================================== -->
    <!-- End Container fluid  -->
}



<script type="text/javascript">
    $(document).ready(function () {
        $("#Type").val('@Model.Type');
        $("#TypeAr").val('@Model.TypeAr');
        $("#Furnishing").val('@Model.Furnishing');
        $("#FurnishingAr").val('@Model.FurnishingAr');
    });

    function DeleteImage(id) {
    Swal.fire({
      title: "Are you sure?",
      text: "You won't be able to revert this!",
        icon: "question",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Yes, delete it!"
      }).then((result) => {
          if (result.isConfirmed) {
             $.ajax({
                 url: "@Url.Action("DeleteImage", "PropertyInformation")",
                 data: { ImageId: id },
                 type: "GET",
                 success: function (response) {
                     location.reload();
                 },
                 error: function (jqXHR, textStatus, errorThrown) {
                     console.log(textStatus, errorThrown);
                 }
             });
          }
    });
    }


    function GetCity(value) {
        $.ajax({
            async: true,
            crossDomain: true,
            type: "GET",

            url: "/admin/get/cities/by/countryId?id=" + value,
            success: function (data) {
                console.log(data);
                //var city = data.data.cities;
                var s = '<option value="-1">Please Select a City</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].CityId + '">' + data[i].CityName + '</option>';
                }
                $("#CityId").html(s);
            }
        });
    }


</script>
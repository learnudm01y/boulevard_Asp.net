@model IEnumerable<Boulevard.Models.UserReport>
@{
    ViewBag.Title = "User Report";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<script type="text/javascript" src="http://code.jquery.com/jquery-1.7.1.min.js"></script>
<!-- Container fluid  -->
<!-- ============================================================== -->
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">User Report</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                    <li class="breadcrumb-item active">User Report</li>
                </ol>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!--order list-->
        <div class="card">
            <div class="card-body">

                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        <h4 class="card-title">User Report List</h4>
                    </div>

                    @*<div class="col-sm-4 text-right">
                        <a href="@Url.RouteUrl("Admin_City_Create_And_Update")" class="btn btn-success  waves-effect">
                            <i class="mdi mdi-plus"></i> Create City
                        </a>
                    </div>*@
                </div>

                <div class="table-responsive">

                    <table id="zero_config" class="table table-striped table-bordered" cellspacing="0" width="100%">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Member Name </th>
                                <th>Email </th>
                                <th>Title </th>
                                <th>Description </th>
                                <th>Reported Date </th>

                                <th>Bolcked Status </th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var data in Model)
                            {
                                <tr>
                                    <td></td>
                                    <td>@data.Member.Name</td>
                                    <td>@data.Member.Email</td>
                                    <td>@data.Title</td>
                                    <td>@data.Comments</td>

                                    <td>@data.LastUpdate</td>

                                    <td>
                                        @if (data.IsActive == true)
                                        {
                                            <button class="btn btn-success">YES</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-block">NO</button>
                                        }
                                    </td>

                                    <td>
                                        @* <a href="@Url.Action("UpdateType","Utilities", new { utilitiesId = data.UtilitiesId })" class="btn btn-success">
                                <i class="fa fa-edit"></i>
                            </a> *@
                                        <a href="@Url.RouteUrl("Admin_ReportandhelpDetails", new { reportId = data.UserReportId })" class="btn btn-warning">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- ============================================================== -->
    </div>
</div>
<!-- ============================================================== -->
<!-- End Container fluid  -->

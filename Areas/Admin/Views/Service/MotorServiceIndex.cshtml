@{
    ViewBag.Title = "Service";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
@model IEnumerable<Boulevard.Models.Service>

<div class="page-wrapper">
    <div class="container-fluid">
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">Motor Service</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                </ol>
            </div>
        </div>

        <div class="card">
            <div class="card-body">

                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        <h4 class="card-title">List</h4>
                    </div>

                    <div class="col-sm-4 text-right">
                        <a href="@Url.RouteUrl("Admin_ServiceCreateOrEditMotorTest")" class="btn btn-success  waves-effect">
                            <i class="mdi mdi-plus"></i> Add
                        </a>
                    </div>
                </div>
                <hr>

                <div class="table-responsive">

                    <table id="zero_config" class="table table-striped table-bordered" cellspacing="0" width="100%">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Service Hour</th>
                                <th>Address</th>
                                <th>Ratings</th>
                                <th style="text-align:center">Image</th>
                                <th>Option</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var node in Model)
                            {
                                <tr>
                                    <td>@node.Name</td>
                                    <td>@node.ServiceHour</td>
                                    <td>@node.Address</td>
                                    <td><i class="fa fa-star" style="color:orange" aria-hidden="true"></i> @node.Ratings</td>
                                    <td style="text-align:center"><img src="@node.AboutUs" style="height:60px" width:"60px" alt="toy" /></td>

                                    <td >
                                        <a href="@Url.RouteUrl("Admin_ServiceCreateOrEditMotorTest", new { Key = node.ServiceKey })" class="btn btn-success btn-xs">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                        <a href="javascript:;" class="btn btn-primary btn-xs" onclick="Delete('@node.ServiceKey')">
                                            <i class="fa fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    function Delete(id) {
        Swal.fire({
          title: "Are you sure?",
          text: "You won't be able to revert this!",
            icon: "question",
          showCancelButton: true,
          confirmButtonColor: "#3085d6",
          cancelButtonColor: "#d33",
          confirmButtonText: "Yes, delete it!"
          }).then((result) => {
              location.reload();
        });
    }
</script>



@{
    ViewBag.Title = "Service";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}


<div class="page-wrapper">
    <div class="container-fluid">
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                @if (ViewBag.FCatagoryKey == null)
                {
                    <h3 class="text-themecolor mb-0">Hotel List</h3>
                }
                else
                {
                    if (ViewBag.FCatagoryKey == "c286a46b-5b9a-4519-bb10-8d47ec254ffb")
                    {
                        <h3 class="text-themecolor mb-0">@ViewBag.FCatagoryName Company List</h3>
                    }
                    else
                    {
                        <h3 class="text-themecolor mb-0">@ViewBag.FCatagoryName Service List</h3>
                    }
                }
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                </ol>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                @if (ViewBag.FCatagoryKey == "c286a46b-5b9a-4519-bb10-8d47ec254ffb")
                {
                    <div class="row align-items-center mb-3">
                        <div class="col-sm-8">
                            <h4 class="card-title">@ViewBag.FCatagoryName Company List</h4>
                        </div>

                        <div class="col-sm-4 text-right">
                            <a href="@Url.RouteUrl("Admin_ServiceCreateOrEdit", new {fCatagoryKey = ViewBag.FCatagoryKey})" class="btn btn-success  waves-effect">
                                <i class="mdi mdi-plus"></i> Add @ViewBag.FCatagoryName Company
                            </a>
                            <a href="@Url.RouteUrl("Admin_AddServiceBulk", new {fCatagoryKey = ViewBag.FCatagoryKey})" type="button" class="btn btn-primary waves-effect">
                                <i class="mdi mdi-upload"></i> Upload Excel
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row align-items-center mb-3">
                        <div class="col-sm-8">
                            <h4 class="card-title">@ViewBag.FCatagoryName Service List</h4>
                        </div>

                        <div class="col-sm-4 text-right">
                            <a href="@Url.RouteUrl("Admin_ServiceCreateOrEdit", new {fCatagoryKey = ViewBag.FCatagoryKey})" class="btn btn-success  waves-effect">
                                <i class="mdi mdi-plus"></i> Add @ViewBag.FCatagoryName Service
                            </a>
                            <a href="@Url.RouteUrl("Admin_AddServiceBulk", new {fCatagoryKey = ViewBag.FCatagoryKey})" type="button" class="btn btn-primary waves-effect">
                                <i class="mdi mdi-upload"></i> Upload Excel
                            </a>
                        </div>
                    </div>
                }
                @*<div class="row align-items-center mb-3">
                        <div class="col-sm-8">
                            <h4 class="card-title">@ViewBag.FCatagoryName Service List</h4>
                        </div>

                        <div class="col-sm-4 text-right">
                            <a href="@Url.RouteUrl("Admin_ServiceCreateOrEdit", new {fCatagoryKey = ViewBag.FCatagoryKey})" class="btn btn-success  waves-effect">
                                <i class="mdi mdi-plus"></i> Add @ViewBag.FCatagoryName Service
                            </a>
                        </div>
                    </div>*@
                <hr>

                <div class="row mb-3">
                    <div class="col-sm-4">
                        <input type="text" id="searchBox" class="form-control" placeholder="Search..." />
                    </div>
                    <div class="col-sm-3">
                        <select id="rowsPerPage" class="form-control">
                            <option value="20">20 per page</option>
                            <option value="50">50 per page</option>
                            <option value="100">100 per page</option>
                            <option value="200">200 per page</option>
                        </select>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Service Hour</th>
                                <th>Address</th>
                                <th>Ratings</th>
                                <th>Option</th>
                            </tr>
                        </thead>
                        <tbody id="serviceTableBody">
                            <tr><td colspan="5" class="text-center">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>

                <div id="paginationContainer" class="mt-3 d-flex justify-content-between align-items-center flex-wrap" style="gap:8px;"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var _page = 1;
    var _pageSize = 20;
    var _searchTerm = '';
    var _fCatagoryKey = '@(ViewBag.FCatagoryKey ?? "")';
    var _totalRecords = 0;

    var _editUrlTpl  = '@(Url.RouteUrl("Admin_ServiceCreateOrEdit", new { Key = "SKEYPH", fCatagoryKey = ViewBag.FCatagoryKey ?? "" }))';
    var _deleteUrl   = '@Url.Action("Delete", "Service")';

    function escHtml(s) {
        if (s == null) return '';
        return String(s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function loadServices() {
        $('#serviceTableBody').html('<tr><td colspan="5" class="text-center">Loading...</td></tr>');
        $.ajax({
            url: '/admin/service-paged',
            data: { fCatagoryKey: _fCatagoryKey, searchTerm: _searchTerm, page: _page, pageSize: _pageSize },
            type: 'GET',
            success: function (res) {
                if (res.success) {
                    _totalRecords = res.total;
                    renderRows(res.rows);
                    renderPagination(res.total);
                } else {
                    $('#serviceTableBody').html('<tr><td colspan="5" class="text-center text-danger">Error loading data.</td></tr>');
                }
            },
            error: function () {
                $('#serviceTableBody').html('<tr><td colspan="5" class="text-center text-danger">Failed to load data.</td></tr>');
            }
        });
    }

    function renderRows(rows) {
        if (!rows || rows.length === 0) {
            $('#serviceTableBody').html('<tr><td colspan="5" class="text-center">No records found.</td></tr>');
            return;
        }
        var html = '';
        for (var i = 0; i < rows.length; i++) {
            var r = rows[i];
            var key = escHtml(r.serviceKey);
            var editUrl = _editUrlTpl.replace('SKEYPH', r.serviceKey);
            html += '<tr>';
            html += '<td>' + escHtml(r.name) + '</td>';
            html += '<td>' + escHtml(r.serviceHour) + '</td>';
            html += '<td>' + escHtml(r.address) + '</td>';
            html += '<td><i class="fa fa-star" style="color:orange" aria-hidden="true"></i> ' + escHtml(r.ratings) + '</td>';
            html += '<td>'
                  + '<a href="' + editUrl + '" class="btn btn-success btn-xs"><i class="fa fa-edit"></i></a> '
                  + '<a href="javascript:;" class="btn btn-primary btn-xs" onclick="Delete(\'' + key + '\')"><i class="fa fa-trash"></i></a>'
                  + '</td>';
            html += '</tr>';
        }
        $('#serviceTableBody').html(html);
    }

    function renderPagination(total) {
        var totalPages = Math.ceil(total / _pageSize) || 1;
        var from = total === 0 ? 0 : (_page - 1) * _pageSize + 1;
        var to   = Math.min(_page * _pageSize, total);
        var info = '<span>Showing ' + from + ' \u2013 ' + to + ' of ' + total + '</span>';
        var btns = '<div>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(1)"' + (_page <= 1 ? ' disabled' : '') + '>&laquo;</button>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(' + (_page - 1) + ')"' + (_page <= 1 ? ' disabled' : '') + '>&lsaquo;</button>';
        var start = Math.max(1, _page - 2);
        var end   = Math.min(totalPages, _page + 2);
        for (var p = start; p <= end; p++) {
            btns += '<button class="btn btn-sm mr-1 ' + (p === _page ? 'btn-primary' : 'btn-outline-secondary') + '" onclick="goPage(' + p + ')">' + p + '</button>';
        }
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(' + (_page + 1) + ')"' + (_page >= totalPages ? ' disabled' : '') + '>&rsaquo;</button>';
        btns += '<button class="btn btn-sm btn-outline-secondary"       onclick="goPage(' + totalPages + ')"' + (_page >= totalPages ? ' disabled' : '') + '>&raquo;</button>';
        btns += '</div>';
        $('#paginationContainer').html(info + btns);
    }

    window.goPage = function(p) {
        var totalPages = Math.ceil(_totalRecords / _pageSize) || 1;
        if (p < 1 || p > totalPages) return;
        _page = p;
        loadServices();
    };

    window.Delete = function(id) {
        Swal.fire({
            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "question",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, delete it!"
        }).then(function (result) {
            if (result.isConfirmed) {
                $.ajax({
                    url: _deleteUrl,
                    data: { Key: id },
                    type: "GET",
                    success: function () { loadServices(); },
                    error: function (jqXHR, textStatus, errorThrown) { console.log(textStatus, errorThrown); }
                });
            }
        });
    }

    var _searchTimer;
    $('#searchBox').on('input', function () {
        clearTimeout(_searchTimer);
        _searchTimer = setTimeout(function () {
            _searchTerm = $('#searchBox').val();
            _page = 1;
            loadServices();
        }, 400);
    });

    $('#rowsPerPage').on('change', function () {
        _pageSize = parseInt($(this).val(), 10);
        _page = 1;
        loadServices();
    });

    $(function () { loadServices(); });
</script>

</script>

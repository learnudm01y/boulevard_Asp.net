@model IEnumerable<Boulevard.Models.CustomerEnquery>
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<script type="text/javascript" src="http://code.jquery.com/jquery-1.7.1.min.js"></script>
<!-- Container fluid  -->
<!-- ============================================================== -->
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">Customer Enquery</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                    <li class="breadcrumb-item active">Customer Enquiry</li>
                </ol>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!--order list-->
        <div class="card">
            <div class="card-body">

                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        <h4 class="card-title">Customer Enquiry List</h4>
                    </div>

                    @*<div class="col-sm-4 text-right">
                        <a href="@Url.RouteUrl("Admin_Order_Status_Create_And_Update")" class="btn btn-success  waves-effect">
                            <i class="mdi mdi-plus"></i> Create Order Status
                        </a>
                    </div>*@
                </div>

                <div class="table-responsive">

                    <table id="zero_config" class="table table-striped table-bordered" cellspacing="0" width="100%">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Message</th>
                                <th>Phone Code</th>
                                <th>Phone Number</th>
                                <th>Feature Category Name</th>
                                <th>Member Name</th>
                                <th>Status</th>
                                <th>Created date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td></td>
                                    <td>@user.Name</td>
                                    <td>@user.Email</td>
                                    <td>@user.Message</td>
                                    <td>@user.PhoneCode</td>
                                    <td>@user.Phonenumber</td>
                                    <td>@user.FeatureCategoryName</td>
                                    <td>@user.UserName</td>
                                    <td>@user.Status</td>
                                    <td>@user.UpdatedAt.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- ============================================================== -->
    </div>
</div>
<!-- ============================================================== -->
<!-- End Container fluid  -->




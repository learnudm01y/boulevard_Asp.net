        var to = false;
        $('#jstree-q').keyup(function () {
            if (to) { clearTimeout(to); }
            to = setTimeout(function () {
                var v = $('#jstree-q').val();
                $('#jstree').jstree(true).search(v);
            }, 250);
        });
    });
</script>

<script>
    let rowIndex = 0;
    const existingPrices = @Html.Raw(JsonConvert.SerializeObject(Model.ProductPrices));
    function renderTable(prices) {
        const tbody = document.getElementById("priceTableBody");
        tbody.innerHTML = ""; // Clear existing rows

        prices.forEach((price, i) => {
            const row = document.createElement("tr");
            row.innerHTML = `
                <td>
                    <input type="number" name="ProductPrices[${rowIndex}].ProductQuantity" class="form-control" required value="${price.ProductQuantity}" />
                    <input type="hidden" name="ProductPrices[${rowIndex}].ProductId" value="${price.ProductId}" />
                    <input type="hidden" name="ProductPrices[${rowIndex}].Status" value="${price.Status}" />
                    <input type="hidden" name="ProductPrices[${rowIndex}].ProductPriceId" value="${price.ProductPriceId}" />
                    <input type="hidden" name="ProductPrices[${rowIndex}].LastUpdateDate" value="${price.LastUpdateDate}" />
                </td>
                <td>
                    <input type="number" name="ProductPrices[${rowIndex}].Price" class="form-control" required step="0.01" value="${price.Price}" />
                </td>
                <td>
                    <input type="number" name="ProductPrices[${rowIndex}].ProductStock" class="form-control" readonly required step="0.01" value="${price.ProductStock}" />
                </td>
               
            `;
            tbody.appendChild(row);
            rowIndex++;
        });
    }
    function addRow() {
        const tbody = document.getElementById("priceTableBody");
        const row = document.createElement("tr");

        const now = new Date().toISOString();

        row.innerHTML = `
            <td>
                <input type="number" name="ProductPrices[${rowIndex}].ProductQuantity" class="form-control" required />
                <input type="hidden" name="ProductPrices[${rowIndex}].ProductId" value="0" />
                <input type="hidden" name="ProductPrices[${rowIndex}].Status" value="Active" />
                <input type="hidden" name="ProductPrices[${rowIndex}].LastUpdateDate" value="${now}" />
            </td>
            <td>
                <input type="number" name="ProductPrices[${rowIndex}].Price" class="form-control" required step="0.01" />
            </td>
            <td>
                <input type="number" name="ProductPrices[${rowIndex}].ProductStock" class="form-control" required step="0.01" />
            </td>
            <td>
                <button type="button" onclick="removeRow(this)" class="btn btn-danger"><i class="fa fa-trash"></i></button>
            </td>
        `;

        tbody.appendChild(row);
        rowIndex++;
    }

    function removeRow(btn) {
        btn.closest("tr").remove();
    }

    function Delete(id) {
    Swal.fire({
      title: "Are you sure?",
      text: "You won't be able to revert this!",
        icon: "question",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Yes, delete it!"
      }).then((result) => {
          if (result.isConfirmed) {
             $.ajax({
                 url: "@Url.Action("DeleteProductPrice", "Product")",
                 data: { productPriceId: id },
                 type: "GET",
                 success: function (response) {
                     location.reload();
                 },
                 error: function (jqXHR, textStatus, errorThrown) {
                     console.log(textStatus, errorThrown);
                 }
             });
          }
    });
}

    renderTable(existingPrices);

    //<td>
    //    <button type="button" onclick="Delete('${price.ProductPriceId}')" class="btn btn-danger"><i class="fa fa-trash"></i></button>
    //</td>

</script>




@* jQuery already loaded in _Head.cshtml - duplicate removed *@
<script>

    function pollFunc(fn, timeout, interval) {
        var startTime = (new Date()).getTime();
        interval = interval || 1000,
            canPoll = true;

        (function p() {
            canPoll = ((new Date).getTime() - startTime) <= timeout;
            if (!fn() && canPoll) { // ensures the function exucutes
                setTimeout(p, interval);
            }
        })();
    }

    pollFunc(autoCall, 60000000, 30000);

    function autoCall() {
        message()
    }



    function message() {
        $.ajax({
            type: "GET",
            url: "/Admin/NotificationListForadmin",
            cache: false,
            success: function (html) {
                $("#messagelisting").html(html);
            },
            error: function (xhr) {

            }
        });



    }

        function SeenOption() {
        $.ajax({
            type: "GET",
            url: "/api/v1/SeenAdminNotification",
            cache: false,
            success: function (html) {

            },
            error: function (xhr) {

            }
        });



    }




</script>
<script>
$(document).ready(function () {
    // Call backend every 30 seconds (was 5s — reduced server load)
    setInterval(function () {
        $.ajax({
            url: '@Url.Action("TriggerAction", "OrderRequestProduct", new { area = "Admin" })',
            type: 'POST',
            success: function (res) {
                if (res.success) {
                    playAudio(); // Play audio only if backend returns success
                }
            },
            error: function () {
                console.error("Failed to call backend.");
            }
        });
    }, 30000); // 30000 ms = 30 seconds
});

    function playAudio() {
        var audio = document.getElementById("audioPlayer");
        if (audio) {
            audio.play().catch(function (err) {
                console.error("Audio play failed:", err);
            });
        }
    }
</script>

<script>
    function MoodChange() {
           $.ajax({
                url: "@Url.Action("MoodChange", "User")",
                type: "GET",
                success: function (response) {
                    location.reload();
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    console.log(textStatus, errorThrown);
                }
            });
    }
</script>

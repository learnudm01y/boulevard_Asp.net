<script src="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.3.16/jstree.min.js"></script>


<script>
    $("#select2-with-tags").select2({
        tags: true
    });

    $(function () {
        $("#jstree").jstree({
            "checkbox": {
                "keep_selected_style": false
            },
            "plugins": ["dnd", "search", "checkbox"]
        });
        var to = false;
        $('#jstree-q').keyup(function () {
            if (to) { clearTimeout(to); }
            to = setTimeout(function () {
                var v = $('#jstree-q').val();
                $('#jstree').jstree(true).search(v);
            }, 250);
        });
    });

    $(function () {
        $("#jstreeBrand").jstree({
            "checkbox": {
                "keep_selected_style": false
            },
            "plugins": ["dnd", "search", "checkbox"]
        });
        var to = false;
        $('#jstreeBrand-q').keyup(function () {
            if (to) { clearTimeout(to); }
            to = setTimeout(function () {
                var v = $('#jstreeBrand-q').val();
                $('#jstreeBrand').jstree(true).search(v);
            }, 250);
        });
    });

    $(function () {
        $("#jstreeGrocery").jstree({
            "checkbox": {
                "keep_selected_style": false
            },

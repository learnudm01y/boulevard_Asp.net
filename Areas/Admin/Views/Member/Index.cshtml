@model Boulevard.Areas.Admin.Data.MemberViewModel

@*@model Boulevard.Areas.Admin.Pagination.PaginatedList<Boulevard.Models.Member>*@
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";



    #region Pagination
    Int64 TotalRecord = 0;
    if (Model.Members.Count() > 0)
    {
        TotalRecord = Model.TotalRecord;
    }

    Int64 ShowingFrom = ((Model.Page - 1) * Model.PageSize) + 1;
    if (ShowingFrom > TotalRecord)
    { ShowingFrom = TotalRecord; }

    Int64 ShowingTo = (Model.Page * Model.PageSize);
    if (ShowingTo > TotalRecord)
    { ShowingTo = TotalRecord; }

    double TotalPage = 1;
    if (TotalRecord > 0)
    {
        TotalPage = Math.Ceiling((double)TotalRecord / (double)Model.PageSize);
        if (TotalPage > 5)
        {


        }
    }
    #endregion
}
<script type="text/javascript" src="http://code.jquery.com/jquery-1.7.1.min.js"></script>
<!-- Container fluid  -->
<!-- ============================================================== -->
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">Member</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                    <li class="breadcrumb-item active">Member</li>
                </ol>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!--order list-->
        <div class="card">
            <div class="card-body">

                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        <h4 class="card-title">Member</h4>
                    </div>

                    <div class="col-sm-4 text-right">
                        <a href="@Url.RouteUrl("Admin_Member_Create_And_Update")" class="btn btn-success  waves-effect">
                            <i class="mdi mdi-plus"></i> Create Member
                        </a>
                    </div>
                </div>


                @using (Html.BeginForm("Index", "Member", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmFilterPagingSize" }))
                {
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <div class="row mb-4 justify-content-between align-items-center">
                                        <div class="col-lg-4 col-md-4 col-sm-12 col-12">
                                            <div class="search-filter">
                                                @*@using (Html.BeginForm("Index", "Member", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmFilterPagingSize" }))
                                                    {*@
                                                @*<div class="col-md-4">*@
                                                <div class="input-group" style="margin-left: 14px;">
                                                    <input type="text" class="form-control" placeholder="Search here..." name="QuickSearchQuery" id="QuickSearchQuery">
                                                    <div class="input-group-append" onclick="ApplyTextSearch()">
                                                        <span class="input-group-text" id="basic-addon1">
                                                            <i class="fa fa-search"></i>
                                                        </span>
                                                    </div>
                                                </div>
                                                @*</div>*@
                                                @*<div class="input-group">
                                                        <input type="text" class="form-control" id="SearchString" name="SearchString" value="@ViewBag.CurrentFilter" placeholder="Search here...">
                                                        <div class="input-group-append">
                                                            <button class="input-group-text" type="submit">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </div>
                                                    </div>*@
                                                @*}*@
                                            </div>
                                        </div>
                                    </div>

                                    <div class="table-responsive" id="reportDiv">
                                        @Html.Partial("~/Areas/Admin/Views/Base/_TableShowing.cshtml")

                                        <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                                            <thead>
                                                <tr>
                                                    <th>Member Name</th>
                                                    <th>Phone Number</th>
                                                    <th>Email</th>
                                                    <th>Address</th>
                                                    <th>MemberShip Name</th>
                                                    <th>Image</th>
                                                    <th>Option</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var user in Model.Members)
                                                {
                                                    <tr>
                                                        <td>@user.Name</td>
                                                        <td>@user.PhoneNumber</td>
                                                        <td>@user.Email</td>
                                                        <td>@user.Address</td>
                                                        @*<td>@user.MemberShipName</td>*@
                                                        @if (user.MemberShipName != null)
                                                        {
                                                            <td><strong style="color:gold">@user.MemberShipName</strong></td>
                                                        }
                                                        else
                                                        {
                                                            <td><strong style="color:red">No MemberShip Available</strong></td>
                                                        }
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(user.Image))
                                                            {
                                                                <img src="@user.Image" style="max-width:50px;max-height:50px;">
                                                            }
                                                            else
                                                            {
                                                                <img src="/Areas/Admin/Content/assets/images/no-image.png" style="max-width:50px;max-height:50px;">
                                                            }
                                                        </td>
                                                        <td>
                                                            <a href="@Url.RouteUrl("Admin_Member_Details", new { key = user.MemberKey })" class="btn btn-info btn-xs">
                                                                <i class="fa fa-eye"></i>
                                                            </a>
                                                            <a href="@Url.RouteUrl("Admin_Member_Create_And_Update", new { key = user.MemberKey })" class="btn btn-success btn-xs">
                                                                <i class="fa fa-edit"></i>
                                                            </a>
                                                            <a href="javascript:;" class="btn btn-primary btn-xs" onclick="Delete(@user.MemberId)">
                                                                <i class="fa fa-trash"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                        @Html.Partial("~/Areas/Admin/Views/Base/_TablePager.cshtml", Model)

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <!-- ============================================================== -->
    </div>
</div>
<!-- ============================================================== -->
<!-- End Container fluid  -->

<script type="text/javascript">

    function Delete(id) {
        const swalWithBootstrapButtons = Swal.mixin({
            customClass: {
                confirmButton: 'btn btn-success',
                cancelButton: 'mr-2 btn btn-danger'
            },
            buttonsStyling: false,
            animation: false,
            allowOutsideClick: false
        })

        swalWithBootstrapButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            type: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: true
        }).then((result) => {
            if (result.value) {
                swalWithBootstrapButtons.fire(
                    'Deleted!',
                    'Your file has been deleted.',
                    'success',

                ).then((sucess) => {
                    // Fire Delete Method
                    $.ajax({
                        url: "@Url.Action("Delete", "Member")/" + id,
                        type: "GET",
                        success: function (response) {
                            location.reload();
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            console.log(textStatus, errorThrown);
                        }
                    });
                })

            }
        })
    }

</script>

<script>
    function ApplyFilters() {
        $("#Page").val('1');
        $("#frmFilterPagingSize").submit();
    }

    function ApplyTextSearch() {
        $("#Page").val('1');
        $("#frmFilterPagingSize").submit();
    }

    $(document).ready(function () {
        $("#ShowingFrom").html('@ShowingFrom');
        $("#ShowingTo").html('@ShowingTo');
        $("#TotalRecord").html('@TotalRecord');

        $("#PageSize").val(@Model.PageSize);
        $("#Page").val('@Model.Page');
        $("#Pager-" + @Model.Page).addClass('active');;
    });
</script>



@model Boulevard.Models.Member

@{
    ViewBag.Title = "Detials";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    table, th, td {
        border: 1px solid black;
        border-collapse: collapse;
        text-align: center;
    }

    table {
        width: 500px;
    }
</style>
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">Member Details</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_Member")">Member</a></li>
                    <li class="breadcrumb-item active">Member Details</li>
                </ol>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!--order list-->
        <form>
            <div class="card">
                <div class="card-header">
                    Member Details
                </div>
                <div class="card-body">
                    <div class="row">
                        <input type="hidden" name="MemberId" class="form-control" value="@Model.MemberId">

                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Member Id : @Model.MemberId</label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Member Key : @Model.MemberKey</label>
                            </div>
                        </div>
                        @*<div class="col-md-12 col-sm-12">
                                <div class="form-group">
                                    <label>Member No : @Model.MemberNo</label>
                                </div>
                            </div>*@
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>
                                    Member Name : @Model.Name
                                </label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Email : @Model.Email</label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Phone Number : @Model.PhoneNumber</label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="card bg-light mb-3" style="width: 18rem;">
                                <img class="card-img-top" src="@Model.Image" alt="Card image cap">
                                <div class="card-body">
                                    <h5 class="card-title">Member Image</h5>
                                </div>
                            </div>
                        </div>


                    </div>
                    <br>
                    <br>
                    <br>
                    <div class="col-md-12 col-sm-12">
                        @*<h1>Member Address Details</h1>*@
                        <div class="row align-items-center mb-3">
                            <div class="col-sm-8">
                                <h1 class="card-title">Member Address Details</h1>
                            </div>

                            <div class="col-sm-4 text-right">
                                <a href="@Url.RouteUrl("Admin_Member_Address_Create_And_Update", new {memberId = ViewBag.MemberId})" class="btn btn-success  waves-effect">
                                    <i class="mdi mdi-plus"></i> Create Member Address
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">

                        <table id="zero_config" class="table table-striped table-bordered" cellspacing="0" width="100%">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Country Name</th>
                                    <th>City Name</th>
                                    <th>Address Line 1</th>
                                    <th>Address Line 2</th>
                                    <th>Near By Address</th>
                                    <th>longitude</th>
                                    <th>latitude</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var node in Model.MemberAddresses)
                                {
                                    <tr>
                                        <td></td>
                                        <td>@node.Country.CountryName</td>
                                        <td>@node.City.CityName</td>
                                        <td>@node.AddressLine1</td>
                                        <td>@node.AddressLine2</td>
                                        <td>@node.NearByAddress</td>
                                        <td>@node.longitude</td>
                                        <td>@node.latitude</td>
                                        <td>
                                            <a href="@Url.RouteUrl("Admin_Member_Address_Create_And_Update", new { key = node.MemberAddressKey})" class="btn btn-success btn-xs">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                            <a href="javascript:;" class="btn btn-primary btn-xs" onclick="Delete(@node.MemberAddressId)">
                                                <i class="fa fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </form>
        <!-- ============================================================== -->
    </div>
</div>


<script type="text/javascript">

    function Delete(id) {
        const swalWithBootstrapButtons = Swal.mixin({
            customClass: {
                confirmButton: 'btn btn-success',
                cancelButton: 'mr-2 btn btn-danger'
            },
            buttonsStyling: false,
            animation: false,
            allowOutsideClick: false
        })

        swalWithBootstrapButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            type: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: true
        }).then((result) => {
            if (result.value) {
                swalWithBootstrapButtons.fire(
                    'Deleted!',
                    'Your file has been deleted.',
                    'success',

                ).then((sucess) => {
                    // Fire Delete Method
                    $.ajax({
                        url: "@Url.Action("Delete", "MemberAddress")/" + id,
                        type: "GET",
                        success: function (response) {
                            location.reload();
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            console.log(textStatus, errorThrown);
                        }
                    });
                })

            }
        })
    }

</script>

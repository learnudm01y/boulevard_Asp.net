                                        <i class="fa fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td>BottomBanner</td>
                                <td>Bottom Banner</td>
                                <td>it over 2000 years old. Richard McClintock, a Latin professor at Hampden-Sydney College in Virginia,</td>
                                <td>
                                    <img src="~/Areas/Admin/Content/assets/images/Test Image/Boulevard 2.png" style="max-width:50px;max-height:50px;">
                                </td>
                                <td>
                                    <a href="@Url.RouteUrl("Admin_WebHtmlTestEdit")" class="btn btn-success btn-xs">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <a href="javascript:;" class="btn btn-primary btn-xs" onclick="Delete()">
                                        <i class="fa fa-trash"></i>
                                    </a>

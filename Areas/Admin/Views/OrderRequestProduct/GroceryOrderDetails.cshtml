@model Boulevard.Models.OrderRequestProduct
@{
    ViewBag.Title = "Grocery Order Details";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    bool hasModel = Model != null;
    var details = hasModel && Model.OrderRequestProduxtDetails != null
        ? Model.OrderRequestProduxtDetails.ToList()
        : new System.Collections.Generic.List<Boulevard.Models.OrderRequestProductDetails>();
    bool anyDeliveryEnabled = details.Any(d => d.IsDeliveryEnabled);
    var byBrand = details.GroupBy(d => new { d.BrandName, d.IsDeliveryEnabled }).ToList();
}

<div class="page-wrapper">
    <div class="container-fluid">

        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">Grocery Order Details</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("GroceryOrderList","OrderRequestProduct")">Grocery Orders</a></li>
                    <li class="breadcrumb-item active">Order Details</li>
                </ol>
            </div>
        </div>

        @if (!hasModel)
        {
            <div class="alert alert-warning">Order not found.</div>
        }
        else
        {
        <!-- Order Header -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Order #@Model.ReadableOrderId</h5>
                <span class="badge badge-@(Model.OrderStatusId == 1 ? "warning" : Model.OrderStatusId == 2 ? "success" : "secondary") p-2">
                    @(Model.OrderStatus != null ? Model.OrderStatus.Name : "Unknown")
                </span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <p><strong>Member:</strong> @(Model.Member != null ? Model.Member.Name : "-")</p>
                        <p><strong>Phone:</strong> @(Model.Member != null ? Model.Member.PhoneNumber : "-")</p>
                        <p><strong>Payment:</strong> @(Model.PaymentMethod != null ? Model.PaymentMethod.PaymentMethodName : "-")</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Order Date:</strong> @Model.OrderDateTime.ToString("dd MMM yyyy HH:mm")</p>
                        <p><strong>Delivery Date:</strong> @Model.DeliveryDateTime.ToString("dd MMM yyyy")</p>
                        <p><strong>Delivery Address:</strong> @(Model.MemberAddresses != null ? Model.MemberAddresses.NearByAddress : "-")</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Subtotal:</strong> @Model.TotalPrice AED</p>
                        <p><strong>Delivery Charge:</strong> @Model.DeliveryCharge AED</p>
                        <p><strong>Grand Total:</strong> <strong>@(Model.TotalPrice + Model.DeliveryCharge) AED</strong></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products grouped by Brand -->
        @foreach (var brandGroup in byBrand)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="mdi mdi-store"></i> @(string.IsNullOrEmpty(brandGroup.Key.BrandName) ? "Unknown Brand" : brandGroup.Key.BrandName)</h6>
                    @if (brandGroup.Key.IsDeliveryEnabled)
                    {
                        <span class="badge badge-success p-2"><i class="fa fa-truck"></i> Shipping Active</span>
                    }
                    else
                    {
                        <span class="badge badge-danger p-2"><i class="fa fa-ban"></i> Shipping Disabled</span>
                    }
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-bordered mb-0" style="border-collapse:collapse">
                        <thead class="thead-light">
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in brandGroup)
                            {
                                <tr>
                                    <td>@(item.Product != null ? item.Product.ProductName : "Product #" + item.ProductId)</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.GrossPrice AED</td>
                                    <td>@(item.Quantity * item.GrossPrice) AED</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Jeeply Tracking section: only if at least one brand has delivery enabled AND a courier order exists -->
        @if (anyDeliveryEnabled && !string.IsNullOrEmpty(Model.CourierOrderId))
        {
            <div class="card mb-3 border-info">
                <div class="card-header bg-info text-white">
                    <i class="mdi mdi-truck-delivery"></i> Jeeply Shipment Tracking
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <p><strong>Courier Order ID:</strong> @Model.CourierOrderId</p>
                        </div>
                        <div class="col-md-4">
                            <p><strong>Rider Name:</strong> @(string.IsNullOrEmpty(Model.RiderName) ? "Not assigned yet" : Model.RiderName)</p>
                        </div>
                        <div class="col-md-4">
                            <p><strong>Rider Phone:</strong> @(string.IsNullOrEmpty(Model.RiderPhone) ? "-" : Model.RiderPhone)</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (!anyDeliveryEnabled)
        {
            <div class="alert alert-warning">
                <i class="fa fa-info-circle"></i> Delivery is <strong>disabled</strong> for all merchants in this order. No Jeeply tracking is available.
            </div>
        }

        <div class="mt-3">
            <a href="@Url.Action("GroceryOrderList","OrderRequestProduct")" class="btn btn-secondary">
                <i class="fa fa-arrow-left"></i> Back to Orders
            </a>
        </div>
        }

    </div>
</div>
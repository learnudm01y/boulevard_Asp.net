<script type="text/javascript">


    var selectedTab = 1;
    function UpdateStatus() {
        var selectedStatus = $("#OrderStatusId").val();
        var checks = $('.chkCheckBoxId:checked');
        var checkedAll = $('.chkCheckBoxId');
        var invoiceIds = [];
        checks.each(function (i, item) {
            invoiceIds.push(item.value);
        });

        if (invoiceIds.length == 0) {
            swalWithBootstrapButtons.fire({
                title: 'Select Table Row',
                text: "Please select at least one item!",
                type: 'warning',
                showCancelButton: false,
                confirmButtonText: 'OK',
                reverseButtons: true
            }).then((result) => {
                return;
            })
            return;
        }
        else {
            $.ajax({
                type: "post",
                url: "@Url.Action("UpdateStatus", "OrderRequestProduct")",
                data: { productIds: invoiceIds, statusId: selectedStatus },
                cache: false,
                success: function (response) {
                    if (response.success) {
                        $('#status').val(selectedStatus);
                        //ApplyFilters();
                        //location.reload();
                    }
                    location.reload();
                },
                error: function (xhr) {

                }
            });
        }
    }

    $(document).ready(function () {
        $('.check-All').on('change', function () {
            var checkedAll = $('.chkCheckBoxId');
            if (this.checked) {
                checkedAll.each(function (i, item) {
                    $('.select-' + item.value).prop('checked', true);
                });
            }
            else {
                checkedAll.each(function (i, item) {
                    $('.select-' + item.value).prop('checked', false);
                });
            }
        });


    });

    function GetData(id) {
        $("#tabId").val(id);
        var tabValue = $("#tabId").val();
        $("#orderStatusForm").submit();
    }

</script>



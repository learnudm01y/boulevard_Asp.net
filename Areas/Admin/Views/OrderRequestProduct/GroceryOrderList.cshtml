@{
    ViewBag.Title = "GroceryOrderList";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int activeTab = ViewBag.OrderStatusActiveId != null ? (int)ViewBag.OrderStatusActiveId : 1;
}
<!-- Container fluid  -->
<div class="page-wrapper">
    <div class="container-fluid">

        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">Order Request Of Grocery</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                    <li class="breadcrumb-item active">Order Request Of Grocery</li>
                </ol>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        <h4 class="card-title">Order Request Of Grocery</h4>
                    </div>
                    <div class="col-sm-4 text-right">
                        <a href="@Url.Action("CreateInvoice", "OrderRequestProduct", new { fCatagoryKey = "3b317e3f-cb2f-4fdd-b9c8-3f2186695771" })" class="btn btn-success btn-sm">
                            <i class="mdi mdi-plus"></i> New Order
                        </a>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">

                                <ul class="nav nav-tabs customtab" role="tablist">
                                    <li class="nav-item">
                                        <button type="button" onclick="switchTab(1)" id="tab-btn-1"
                                                class="nav-link @(activeTab == 1 ? "active" : "")" style="color:black">
                                            <span class="hidden-xs-down font-medium">Order Placed</span>
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button type="button" onclick="switchTab(2)" id="tab-btn-2"
                                                class="nav-link @(activeTab == 2 ? "active" : "")" style="color:black">
                                            <span class="hidden-xs-down font-medium">Order Delivered</span>
                                        </button>
                                    </li>
                                </ul>

                                <div class="tab-content">

                                    <div class="tab-pane @(activeTab == 1 ? "active pt-3" : "")" id="tab-pane-1" role="tabpanel">
                                        <div class="table-responsive m-t-20">
                                            <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                                                <thead>
                                                    <tr>
                                                        <th>Order #</th>
                                                        <th>Member Name</th>
                                                        <th>Order Date</th>
                                                        <th>Delivery Date</th>
                                                        <th>Total Price</th>
                                                        <th>Status</th>
                                                        <th>Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tbody-1">
                                                    <tr><td colspan="7" class="text-center"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>

                                    <div class="tab-pane @(activeTab == 2 ? "active pt-3" : "")" id="tab-pane-2" role="tabpanel">
                                        <div class="table-responsive m-t-20">
                                            <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                                                <thead>
                                                    <tr>
                                                        <th>Order #</th>
                                                        <th>Member Name</th>
                                                        <th>Order Date</th>
                                                        <th>Delivery Date</th>
                                                        <th>Total Price</th>
                                                        <th>Status</th>
                                                        <th>Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tbody-2">
                                                    <tr><td colspan="7" class="text-center"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<script type="text/javascript">
    var GROCERY_KEY = '3b317e3f-cb2f-4fdd-b9c8-3f2186695771';
    var detailsBase = '@Url.RouteUrl("Admin_Order_Request_GroceryOrderDetails", new { id = "__ID__" })'.replace('__ID__', '');
    var loadedTabs = {};

    function switchTab(tabId) {
        for (var i = 1; i <= 2; i++) {
            document.getElementById('tab-btn-' + i).classList.remove('active');
            document.getElementById('tab-pane-' + i).className = 'tab-pane';
        }
        document.getElementById('tab-btn-' + tabId).classList.add('active');
        document.getElementById('tab-pane-' + tabId).className = 'tab-pane active pt-3';
        if (!loadedTabs[tabId]) {
            loadOrders(tabId);
        }
    }

    function loadOrders(statusId) {
        var tbody = document.getElementById('tbody-' + statusId);
        tbody.innerHTML = '<tr><td colspan="7" class="text-center"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>';

        $.ajax({
            type: 'POST',
            url: '@Url.Action("GetPagedOrders", "OrderRequestProduct")',
            data: { fCatagoryKey: GROCERY_KEY, statusId: statusId, page: 1, pageSize: 100 },
            success: function (res) {
                if (res.success && res.rows && res.rows.length > 0) {
                    var html = '';
                    $.each(res.rows, function (i, o) {
                        var viewUrl = detailsBase + o.OrderRequestProductId;
                        var badge = '<span class="badge badge-' + (o.OrderStatusId === 1 ? 'warning' : 'success') + '">' + o.OrderStatusName + '</span>';
                        html += '<tr>';
                        html += '<td><strong>#' + (o.ReadableOrderId || o.OrderRequestProductId) + '</strong></td>';
                        html += '<td>' + (o.MemberName || '') + '</td>';
                        html += '<td>' + o.OrderDate + '</td>';
                        html += '<td>' + o.DeliveryDate + '</td>';
                        html += '<td>' + o.TotalPrice + ' AED</td>';
                        html += '<td>' + badge + '</td>';
                        html += '<td><a href="' + viewUrl + '" class="btn btn-info btn-xs"><i class="fa fa-eye"></i> View</a></td>';
                        html += '</tr>';
                    });
                    tbody.innerHTML = html;
                } else {
                    tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted">No orders found.</td></tr>';
                }
                loadedTabs[statusId] = true;
            },
            error: function () {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center text-danger">Failed to load orders. Please refresh.</td></tr>';
            }
        });
    }

    $(document).ready(function () {
        loadOrders(@activeTab);
    });
</script>

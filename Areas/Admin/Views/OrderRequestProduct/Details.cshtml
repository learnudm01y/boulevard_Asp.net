@model Boulevard.Models.OrderRequestProduct

@{
    ViewBag.Title = "Detials";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    table, th, td {
        border: 1px solid black;
        border-collapse: collapse;
        text-align: center;
    }

    table {
        width: 500px;
    }
</style>
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">@Model.FeatureCategory.Name Order Details</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_Member")">Member</a></li>
                    <li class="breadcrumb-item active">@Model.FeatureCategory.Name Order Details</li>
                </ol>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!--order list-->
        <form>
            <div class="card">
                <div class="card-header">
                    @Model.FeatureCategory.Name Order Details
                </div>
                <div class="card-body">
                    <div class="row">
                        <input type="hidden" name="MemberId" class="form-control" value="@Model.MemberId">

                        <div class="col-md-6 col-sm-12">
                            <div class="form-group">
                                <label>Order Number : @Model.ReadableOrderId</label>
                            </div>
                            @*</div>
                <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Member Name : <span style="font-size:large">@Model.Member.Name</span></label>
                            </div>
                            @*</div>
                <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Member Address : <span style="font-size:large">@(Model.MemberAddresses != null ? Model.MemberAddresses.AddressLine1 : "N/A")</span></label>
                            </div>
                            @*</div>
                <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Member No : @Model.Member.PhoneNumber</label>
                            </div>
                            @*</div>
                <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>
                                    Member Address : @(Model.MemberAddresses != null ? Model.MemberAddresses.NearByAddress : "N/A")
                                </label>
                            </div>
                            @*</div>
                <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>
                                    Comments : @Model.Comments
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <div class="form-group">
                                <label>Order Date : @Model.OrderDateTime.ToString("dd/MM/yyyy")</label>
                            </div>
                            @*</div>
        <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Delivery Date : @Model.DeliveryDateTime.ToString("dd/MM/yyyy")</label>
                            </div>
                            @*</div>
        <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Delivery Charge : @Model.DeliveryCharge</label>
                            </div>
                            <div class="form-group">
                                <label>Service Charge : @Model.ServiceCharge</label>
                            </div>
                            @*</div>
        <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Total Price : @Model.TotalPrice</label>
                            </div>
                            @*</div>
        <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Payment Method Name : @Model.PaymentMethod.PaymentMethodName</label>
                            </div>

                            <div class="form-group">
                                <label>Payment Status : @Model.PaymentStatus</label>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.PaymentTransectionId))
                            {
                                <div class="form-group">
                                    <label>Payment TransectionId: @Model.PaymentTransectionId</label>
                                </div>
                            }

                            @*</div>
        <div class="col-md-12 col-sm-12">*@
                            <div class="form-group">
                                <label>Order Status : <strong>@Model.OrderStatus.Name</strong></label>
                            </div>
                            @if (Model.IsCanceled == true)
                            {
                                <div class="form-group">
                                    <label>Canceled Reason : <strong>@Model.CancelReason</strong></label>
                                </div>
                            }

                            <div class="form-group">
                                <label>Courier OrderId : <strong>@Model.CourierOrderId</strong></label>
                            </div>

                            <div class="form-group">
                                <label>Rider Name : <strong>@Model.RiderName</strong></label>
                            </div>
                            <div class="form-group">
                                <label>Rider Phone No : <strong>@Model.RiderPhone</strong></label>
                            </div>

                        </div>
                        @*<div class="col-md-12 col-sm-12">
                <div class="card bg-light mb-3" style="width: 18rem;">
                    <img class="card-img-top" src="@Model.Image" alt="Card image cap">
                    <div class="card-body">
                        <h5 class="card-title">Member Image</h5>
                    </div>
                </div>
            </div>*@


                    </div>
                    @if (Model.OrderStatushistory != null && Model.OrderStatushistory.Count > 0)
                    {
                        <div class="row">
                            <!-- Column -->
                            <div class="col-md-12">
                                <h3>Delivery Status</h3>
                                <div class="card">
                                    <div class="card-body">


                                        <div class="row" id="StatusResponse">
                                            @*<div class="col-12" style="border-right: 1px solid #d3d3d3">
                                    <h2 style="text-align: center;" id="StatusResponse"><strong>@OrderDataAccess.getSingleStatusName(Model.InvoiceStatusId)</strong></h2>
                                </div>*@
                                            @if (Model.OrderStatushistory != null && Model.OrderStatushistory.Count > 0)
                                            {
                                                Html.RenderPartial("PartialViews/OrderStatusView", Model.OrderStatushistory);
                                            }
                                            @*else
                                {
                                    <div class="col-12" style="border-right: 1px solid #d3d3d3">
                                        <h3 style="text-align: center; color:green"><strong>Status has been updated as pending</strong></h3>
                                    </div>
                                }*@
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                        <br>
                        <br>
                        <br>
                        <div class="col-md-12 col-sm-12">
                            @*<h1>Order Details</h1>*@
                            <div class="form-group" style="text-align:center">
                                <h1>@Model.FeatureCategory.Name Order List</h1>
                                @*<label style="font-size:30px">Total Price : @Model.TotalPrice</label>*@
                            </div>
                        </div>
                        <div class="table-responsive">

                            <table id="zero_config" class="table table-striped table-bordered" cellspacing="0" width="100%">
                                <thead>
                                    <tr>

                                        <th>Product Name</th>
                                        <th>Brand Name</th>
                                        <th>Product Description</th>
                                        <th>Product Price</th>
                                        <th>Quantity</th>
                                        <th>Price</th>
                                        <th>Gross Price</th>

                                        <th>Discount Name</th>

                                        <th>Amount Discount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var node in Model.OrderRequestProduxtDetails)
                                    {
                                        var description = "exampleModal" + node.Product.ProductId;
                                        var grossPrize = @node.GrossPrice * @node.Quantity;
                                        <tr>
                                            <td>@node.Product.ProductName</td>
                                            <td>@node.BrandName</td>
                                            <td>
                                                <a href="javascript:void(0);" style="font-size: 20px; line-height: 1; color: #202020;" data-toggle="modal" data-target="#@description">
                                                    <i class="bi bi-info-circle-fill"></i>
                                                </a>
                                            </td>
                                            <td>@node.Product.ProductPrice</td>
                                            <td>@node.Quantity</td>
                                            <td>@node.GrossPrice</td>
                                            <td>@grossPrize</td>
                                            @*<td></td>*@
                                            @if (node.IsOffer == true)
                                            {
                                                <td>@node.OfferName</td>
                                            }
                                            else
                                            {
                                                <td></td>
                                            }

                                            @if (node.IsMemberShipOffer == true)
                                            {
                                                <td>@node.MemberShipName</td>
                                            }
                                            @if (!string.IsNullOrEmpty(node.OfferDiscountType))
                                            {
                                                if (node.OfferDiscountType == "Percentage")
                                                {
                                                    <td>@node.DiscountAmount %</td>
                                                }
                                                else
                                                {
                                                    <td>@node.DiscountAmount AED</td>
                                                }
                                            }
                                            else
                                            {
                                                <td>@node.DiscountAmount</td>
                                            }
                                        </tr>


                                        <div class="modal fade" id="@description" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title" id="exampleModalLabel">Description</h5>
                                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                            <span aria-hidden="true">&times;</span>
                                                        </button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p>@Html.Raw(node.Product.ProductDescription)</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </tbody>
                            </table>

                        </div>
                    </div>
            </div>
        </form>
        <!-- ============================================================== -->
    </div>
</div>



<script type="text/javascript">

    function Delete(id) {
        const swalWithBootstrapButtons = Swal.mixin({
            customClass: {
                confirmButton: 'btn btn-success',
                cancelButton: 'mr-2 btn btn-danger'
            },
            buttonsStyling: false,
            animation: false,
            allowOutsideClick: false
        })

        swalWithBootstrapButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            type: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: true
        }).then((result) => {
            if (result.value) {
                swalWithBootstrapButtons.fire(
                    'Deleted!',
                    'Your file has been deleted.',
                    'success',

                ).then((sucess) => {
                    // Fire Delete Method
                    $.ajax({
                        url: "@Url.Action("Delete", "MemberAddress")/" + id,
                        type: "GET",
                        success: function (response) {
                            location.reload();
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            console.log(textStatus, errorThrown);
                        }
                    });
                })

            }
        })
    }

</script>

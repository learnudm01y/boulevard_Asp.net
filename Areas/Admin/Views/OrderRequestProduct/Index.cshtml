@model Boulevard.ResponseModel.OrderRequestProductResponse
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<style>
.skel-bar {
    height: 14px;
    border-radius: 4px;
    background: linear-gradient(90deg, #ececec 25%, #f5f5f5 50%, #ececec 75%);
    background-size: 200% 100%;
    animation: skel-shimmer 1.4s infinite;
    display: block;
}
@@keyframes skel-shimmer {
    0%   { background-position:  200% 0; }
    100% { background-position: -200% 0; }
}
.skel-row td { padding: 10px 8px !important; vertical-align: middle; }
</style>
<!-- Container fluid  -->
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- Breadcrumb -->
        @if (ViewBag.FCatagoryKey != null)
        {
            <div class="row page-titles">
                <div class="col-md-5 col-12 align-self-center">
                    <h3 class="text-themecolor mb-0">Order Request @ViewBag.FCatagoryName Product</h3>
                </div>
                <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                        <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                        <li class="breadcrumb-item active">Order Request @ViewBag.FCatagoryName Product</li>
                    </ol>
                </div>
            </div>
        }
        else
        {
            <div class="row page-titles">
                <div class="col-md-5 col-12 align-self-center">
                    <h3 class="text-themecolor mb-0">Order Request Product</h3>
                </div>
                <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                        <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                        <li class="breadcrumb-item active">Order Request Product</li>
                    </ol>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body">

                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        @if (ViewBag.FCatagoryKey != null)
                        {
                            <h4 class="card-title">Order Request @ViewBag.FCatagoryName Product</h4>
                        }
                        else
                        {
                            <h4 class="card-title">Order Request Product</h4>
                        }
                    </div>
                    <div class="col-sm-4 text-right">
                        @if (ViewBag.FCatagoryKey != null)
                        {
                            <a href="@Url.RouteUrl("Admin_Order_CreateInvoice", new { fCatagoryKey = ViewBag.FCatagoryKey })"
                               class="btn btn-success waves-effect">
                                <i class="mdi mdi-plus"></i> Create Invoice
                            </a>
                        }
                    </div>
                </div>

                <!-- Filters row -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="font-weight-bold">Order Status</label>
                        <select id="statusFilter" class="form-control">
                            @foreach (var item in ViewBag.OrderStatus)
                            {
                                <option value="@item.OrderStatusId"
                                        @(ViewBag.OrderStatusActiveId == item.OrderStatusId ? "selected" : "")>
                                    @item.Name
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="font-weight-bold">Rows per page</label>
                        <select id="pageSizeSelect" class="form-control">
                            <option value="10">10</option>
                            <option value="20" selected>20</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                            <option value="200">200</option>
                            <option value="500">500</option>
                        </select>
                    </div>
                    <div class="col-md-7 align-self-end">
                        <span id="resultsInfo" class="text-muted small"></span>
                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive" style="min-height:420px">
                    <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                        <thead>
                            <tr>
                                <th style="width:40px">
                                    <input type="checkbox" id="check-all">
                                </th>
                                <th>#</th>
                                <th>Order ID</th>
                                <th>Member Name</th>
                                <th>Order Date</th>
                                <th>Delivery Date</th>
                                <th>Total Price</th>
                                <th>Order Status</th>
                                <th>Options</th>
                            </tr>
                        </thead>
                        <tbody id="ordersTableBody">
                            <tr class="skel-row"><td><input type="checkbox" disabled></td><td><div class="skel-bar" style="width:28px"></div></td><td><div class="skel-bar" style="width:90px"></div></td><td><div class="skel-bar" style="width:130px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:60px"></div></td><td><div class="skel-bar" style="width:90px;height:22px"></div></td><td><div class="skel-bar" style="width:80px;height:22px"></div></td></tr>
                            <tr class="skel-row"><td><input type="checkbox" disabled></td><td><div class="skel-bar" style="width:28px"></div></td><td><div class="skel-bar" style="width:95px"></div></td><td><div class="skel-bar" style="width:110px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:55px"></div></td><td><div class="skel-bar" style="width:90px;height:22px"></div></td><td><div class="skel-bar" style="width:80px;height:22px"></div></td></tr>
                            <tr class="skel-row"><td><input type="checkbox" disabled></td><td><div class="skel-bar" style="width:28px"></div></td><td><div class="skel-bar" style="width:85px"></div></td><td><div class="skel-bar" style="width:145px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:65px"></div></td><td><div class="skel-bar" style="width:90px;height:22px"></div></td><td><div class="skel-bar" style="width:80px;height:22px"></div></td></tr>
                            <tr class="skel-row"><td><input type="checkbox" disabled></td><td><div class="skel-bar" style="width:28px"></div></td><td><div class="skel-bar" style="width:100px"></div></td><td><div class="skel-bar" style="width:120px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:70px"></div></td><td><div class="skel-bar" style="width:90px;height:22px"></div></td><td><div class="skel-bar" style="width:80px;height:22px"></div></td></tr>
                            <tr class="skel-row"><td><input type="checkbox" disabled></td><td><div class="skel-bar" style="width:28px"></div></td><td><div class="skel-bar" style="width:88px"></div></td><td><div class="skel-bar" style="width:135px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:80px"></div></td><td><div class="skel-bar" style="width:58px"></div></td><td><div class="skel-bar" style="width:90px;height:22px"></div></td><td><div class="skel-bar" style="width:80px;height:22px"></div></td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="row mt-3">
                    <div class="col-sm-5">
                        <span id="paginationInfo" class="text-muted small"><span class="skel-bar d-inline-block" style="width:180px;height:12px"></span></span>
                    </div>
                    <div class="col-sm-7">
                        <nav aria-label="Orders pagination">
                            <ul class="pagination justify-content-end mb-0" id="paginationControls">
                                <li class="page-item disabled"><span class="page-link">&laquo;</span></li>
                                <li class="page-item disabled"><span class="page-link" style="min-width:40px"><span class="skel-bar d-inline-block" style="width:18px;height:12px"></span></span></li>
                                <li class="page-item disabled"><span class="page-link" style="min-width:40px"><span class="skel-bar d-inline-block" style="width:18px;height:12px"></span></span></li>
                                <li class="page-item disabled"><span class="page-link" style="min-width:40px"><span class="skel-bar d-inline-block" style="width:18px;height:12px"></span></span></li>
                                <li class="page-item disabled"><span class="page-link">&raquo;</span></li>
                            </ul>
                        </nav>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var _currentPage = 1;
    var _pageSize    = 20;
    var _statusId    = @ViewBag.OrderStatusActiveId;
    var _fCatagoryKey = '@(ViewBag.FCatagoryKey ?? string.Empty)';
    var _totalRows   = 0;
    var _countXhr    = null;

    // ── sessionStorage count cache (TTL 2 min) ──────────────────
    function _getCachedCount() {
        try {
            var k = 'orp_c_' + _fCatagoryKey + '_' + _statusId;
            var v = sessionStorage.getItem(k), t = sessionStorage.getItem(k + '_t');
            if (v && t && (Date.now() - (+t)) < 120000) return +v;
        } catch(e) {}
        return null;
    }
    function _setCachedCount(n) {
        try {
            var k = 'orp_c_' + _fCatagoryKey + '_' + _statusId;
            sessionStorage.setItem(k, n);
            sessionStorage.setItem(k + '_t', Date.now());
        } catch(e) {}
    }
    function _clearCachedCount() {
        try {
            var k = 'orp_c_' + _fCatagoryKey + '_' + _statusId;
            sessionStorage.removeItem(k); sessionStorage.removeItem(k + '_t');
        } catch(e) {}
    }

    // ── Skeleton helpers ─────────────────────────────────────────
    function skelBar(w) {
        return '<div class="skel-bar" style="width:' + (w || '100%') + '"></div>';
    }
    function skelRows(n) {
        var widths = [
            [28,90,130,80,80,60],[28,95,110,80,80,55],
            [28,85,145,80,80,65],[28,100,120,80,80,70],[28,88,135,80,80,58]
        ];
        var html = '';
        for (var i = 0; i < n; i++) {
            var w = widths[i % widths.length];
            html += '<tr class="skel-row">';
            html += '<td><input type="checkbox" disabled></td>';
            for (var j = 0; j <= 5; j++) html += '<td>' + skelBar(w[j] + 'px') + '</td>';
            html += '<td><div class="skel-bar" style="width:90px;height:22px"></div></td>';
            html += '<td><div class="skel-bar" style="width:80px;height:22px"></div></td>';
            html += '</tr>';
        }
        return html;
    }
    function skelPagCtrl() {
        return '<li class="page-item disabled"><span class="page-link">&laquo;</span></li>' +
               '<li class="page-item disabled"><span class="page-link" style="min-width:40px"><span class="skel-bar d-inline-block" style="width:18px;height:12px"></span></span></li>'.repeat(3) +
               '<li class="page-item disabled"><span class="page-link">&raquo;</span></li>';
    }

    // ── PREFETCH: fire AJAX immediately ──────────────────────────
    // jQuery is already loaded from _Head.cshtml (in <head>).
    // This runs BEFORE _Scripts.cshtml — so the SQL query executes
    // while the browser is still downloading all the heavy libraries.
    // By the time $(document).ready fires, the data is already here.
    (function prefetch() {
        $.ajax({
            type: 'POST',
            url: '/admin/order/request/product/paged-orders',
            data: { fCatagoryKey: _fCatagoryKey, statusId: _statusId, page: 1, pageSize: _pageSize },
            success: function (res) {
                if (!res.success) {
                    $('#ordersTableBody').html('<tr><td colspan="9" class="text-center text-danger">Failed to load data.</td></tr>');
                    return;
                }
                renderRows(res.rows);
                renderPaginationHasMore(res.rows && res.rows.length === _pageSize);
                loadCount(true);
            },
            error: function () {
                $('#ordersTableBody').html('<tr><td colspan="9" class="text-center text-danger">Error loading data. Please refresh.</td></tr>');
            }
        });
    })();

    // ── loadOrders: used for filter / page changes ───────────────
    function loadOrders() {
        _clearCachedCount();
        _totalRows = 0;
        if (_countXhr) { _countXhr.abort(); _countXhr = null; }
        $('#ordersTableBody').html(skelRows(5));
        $('#paginationInfo').html('');
        $('#paginationControls').html(skelPagCtrl());

        $.ajax({
            type: 'POST',
            url: '/admin/order/request/product/paged-orders',
            data: { fCatagoryKey: _fCatagoryKey, statusId: _statusId, page: _currentPage, pageSize: _pageSize },
            success: function (res) {
                if (!res.success) {
                    $('#ordersTableBody').html('<tr><td colspan="9" class="text-center text-danger">Failed to load data.</td></tr>');
                    return;
                }
                renderRows(res.rows);
                renderPaginationHasMore(res.rows && res.rows.length === _pageSize);
                loadCount(false);
            },
            error: function () {
                $('#ordersTableBody').html('<tr><td colspan="9" class="text-center text-danger">Error loading data. Please try again.</td></tr>');
            }
        });
    }

    // ── COUNT: async, cached ─────────────────────────────────────
    function loadCount(useCache) {
        if (useCache) {
            var cached = _getCachedCount();
            if (cached !== null) { _applyCount(cached); return; }
        }
        $('#paginationInfo').html('<small class="text-muted">Counting&hellip;</small>');
        _countXhr = $.ajax({
            type: 'POST',
            url: '/admin/order/request/product/paged-orders-count',
            data: { fCatagoryKey: _fCatagoryKey, statusId: _statusId },
            success: function (res) {
                _countXhr = null;
                if (!res.success) return;
                _setCachedCount(res.total);
                _applyCount(res.total);
            },
            error: function () { _countXhr = null; }
        });
    }
    function _applyCount(total) {
        _totalRows = total;
        var start = (_currentPage - 1) * _pageSize + 1;
        var end   = Math.min(_currentPage * _pageSize, total);
        $('#paginationInfo').text('Showing ' + start + ' to ' + end + ' of ' + total + ' entries');
        renderPagination(total);
    }

    // ── Render rows ──────────────────────────────────────────────
    function renderRows(rows) {
        if (!rows || rows.length === 0) {
            $('#ordersTableBody').html('<tr><td colspan="9" class="text-center">No records found.</td></tr>');
            $('#paginationInfo').text('');
            return;
        }
        var html = '';
        var startIndex = (_currentPage - 1) * _pageSize + 1;
        $.each(rows, function (i, row) {
            var statusClass = (row.OrderStatusName === 'Order Delivered') ? 'btn-dark-danger' : 'btn-success';
            html += '<tr>';
            html += '<td><input type="checkbox" class="chkCheckBoxId" value="' + row.OrderRequestProductId + '"></td>';
            html += '<td>' + (startIndex + i) + '</td>';
            html += '<td>' + escHtml(row.ReadableOrderId) + '</td>';
            html += '<td>' + escHtml(row.MemberName) + '</td>';
            html += '<td>' + escHtml(row.OrderDate) + '</td>';
            html += '<td>' + escHtml(row.DeliveryDate) + '</td>';
            html += '<td>' + escHtml(row.TotalPrice) + '</td>';
            html += '<td><button class="btn ' + statusClass + ' btn-xs"><span>' + escHtml(row.OrderStatusName) + '</span></button></td>';
            html += '<td>';
            html += '<a href="/admin/order/request/product/details/' + row.OrderRequestProductId + '" class="btn btn-info btn-xs" title="Details"><i class="fa fa-eye"></i></a> ';
            html += '<a href="/admin/order/request/product/invoice/' + row.OrderRequestProductId + '" class="btn btn-primary btn-xs" title="Invoice"><i class="fas fa-print"></i></a> ';
            html += '<a href="/admin/order/request/product/delivary-ship/' + row.OrderRequestProductId + '" class="btn btn-success btn-xs" title="Delivery Slip"><i class="fas fa-print"></i></a>';
            html += '</td>';
            html += '</tr>';
        });
        $('#ordersTableBody').html(html);
    }

    // ── Pagination ───────────────────────────────────────────────
    function renderPaginationHasMore(hasMore) {
        var html = '';
        html += '<li class="page-item' + (_currentPage <= 1 ? ' disabled' : '') + '">';
        html += '<a class="page-link" href="#" data-page="' + (_currentPage - 1) + '">&laquo; Prev</a></li>';
        html += '<li class="page-item active"><span class="page-link">' + _currentPage + '</span></li>';
        if (hasMore) {
            html += '<li class="page-item"><a class="page-link" href="#" data-page="' + (_currentPage + 1) + '">Next &raquo;</a></li>';
        }
        $('#paginationControls').html(html);
    }
    function renderPagination(total) {
        var totalPages = Math.ceil(total / _pageSize);
        if (totalPages <= 1) { $('#paginationControls').html(''); return; }
        var html = '';
        html += '<li class="page-item' + (_currentPage <= 1 ? ' disabled' : '') + '">';
        html += '<a class="page-link" href="#" data-page="' + (_currentPage - 1) + '">&laquo;</a></li>';
        var startPage = Math.max(1, _currentPage - 2);
        var endPage   = Math.min(totalPages, _currentPage + 2);
        if (startPage > 1) {
            html += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';
            if (startPage > 2) html += '<li class="page-item disabled"><span class="page-link">&hellip;</span></li>';
        }
        for (var p = startPage; p <= endPage; p++) {
            html += '<li class="page-item' + (p === _currentPage ? ' active' : '') + '">';
            html += '<a class="page-link" href="#" data-page="' + p + '">' + p + '</a></li>';
        }
        if (endPage < totalPages) {
            if (endPage < totalPages - 1) html += '<li class="page-item disabled"><span class="page-link">&hellip;</span></li>';
            html += '<li class="page-item"><a class="page-link" href="#" data-page="' + totalPages + '">' + totalPages + '</a></li>';
        }
        html += '<li class="page-item' + (_currentPage >= totalPages ? ' disabled' : '') + '">';
        html += '<a class="page-link" href="#" data-page="' + (_currentPage + 1) + '">&raquo;</a></li>';
        $('#paginationControls').html(html);
    }

    function escHtml(str) {
        if (str == null) return '';
        return String(str)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // ── DOM ready: attach event handlers only ────────────────────
    // Data was already prefetched above — no data loading here.
    $(document).ready(function () {

        $('#statusFilter').on('change', function () {
            _statusId = parseInt($(this).val());
            _currentPage = 1;
            loadOrders();
        });

        $('#pageSizeSelect').on('change', function () {
            _pageSize = parseInt($(this).val());
            _currentPage = 1;
            loadOrders();
        });

        $('#check-all').on('change', function () {
            $('.chkCheckBoxId').prop('checked', this.checked);
        });

        $(document).on('click', '#paginationControls .page-link', function (e) {
            e.preventDefault();
            var page = parseInt($(this).data('page'));
            if (isNaN(page) || page < 1) return;
            if (_totalRows > 0) {
                var totalPages = Math.ceil(_totalRows / _pageSize);
                if (page > totalPages) return;
            }
            _currentPage = page;
            window.scrollTo(0, 0);
            loadOrders();
        });
    });
</script>

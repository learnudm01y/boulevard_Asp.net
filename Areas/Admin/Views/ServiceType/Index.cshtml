@{
    ViewBag.Title = "Service Amenity";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<div class="page-wrapper">
    <div class="container-fluid">
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                @if (!string.IsNullOrEmpty(ViewBag.FCatagoryKey))
                {
                    if (ViewBag.FCatagoryKey == "6440039B-6E5A-4E65-A0E4-F38B69C46C8C")
                    {
                        <h3 class="text-themecolor mb-0">Room Service Type</h3>
                    }
                    else
                    {
                        <h3 class="text-themecolor mb-0">@ViewBag.FCatagoryName Service Type</h3>
                    }
                }
                else
                {
                    <h3 class="text-themecolor mb-0">Service Type</h3>
                }
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                </ol>
            </div>
        </div>

        <div class="card">
            <div class="card-body">

                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        @if (ViewBag.FCatagoryKey == "6440039B-6E5A-4E65-A0E4-F38B69C46C8C")
                        {
                            <h4 class="card-title">Rooms List</h4>
                        }
                        else
                        {
                            <h4 class="card-title">@ViewBag.FCatagoryName List</h4>
                        }
                    </div>

                    <div class="col-sm-4 text-right">
                        @*@if (ViewBag.FCatagoryKey == "6440039B-6E5A-4E65-A0E4-F38B69C46C8C")
                        {
                            <a href="@Url.RouteUrl("Admin_ServiceTypeCreateOrEditV2", new { fCatagoryKey = ViewBag.FCatagoryKey })" class="btn btn-success  waves-effect">
                                <i class="mdi mdi-plus"></i> Add Rooms
                            </a>
                        }
                        else
                        {*@
                            <a href="@Url.RouteUrl("Admin_ServiceTypeCreateOrEditV2", new { fCatagoryKey = ViewBag.FCatagoryKey })" class="btn btn-success  waves-effect">
                                <i class="mdi mdi-plus"></i> Add @ViewBag.FCatagoryName
                            </a>
                        @*}*@
                        @*<a href="@Url.RouteUrl("Admin_ServiceType_bulk", new {fCatagoryKey = ViewBag.FCatagoryKey})" type="button" class="btn btn-primary waves-effect">
                            <i class="mdi mdi-upload"></i> Upload Excel
                        </a>*@

                        <a href="@Url.RouteUrl("Admin_AddServiceBulk", new {fCatagoryKey = ViewBag.FCatagoryKey})" type="button" class="btn btn-primary waves-effect">
                            <i class="mdi mdi-upload"></i> Upload Excel
                        </a>
                    </div>
                </div>
                <hr>

                <div class="row mb-3">
                    <div class="col-sm-4">
                        <input type="text" id="searchBox" class="form-control" placeholder="Search..." />
                    </div>
                    <div class="col-sm-3">
                        <select id="rowsPerPage" class="form-control">
                            <option value="20">20 per page</option>
                            <option value="50">50 per page</option>
                            <option value="100">100 per page</option>
                            <option value="200">200 per page</option>
                        </select>
                    </div>
                </div>

                <div class="table-responsive" style="min-height:420px">
                    <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Service Name</th>
                                <th>Person Quantity</th>
                                <th>Size</th>
                                <th>Price</th>
                                <th>Image</th>
                                <th>Option</th>
                            </tr>
                        </thead>
                        <tbody id="stTableBody">
                            <tr><td colspan="7" class="text-center">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
                <span id="paginationInfo"></span>
                <div id="paginationContainer" class="mt-2 d-flex justify-content-between align-items-center flex-wrap" style="gap:8px;"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
$(function () {
    var _page = 1, _pageSize = 20, _searchTerm = '', _totalRecords = -1, _countXhr = null;
    var _fCatagoryKey = '@(ViewBag.FCatagoryKey ?? "")';
    var _editUrlTpl = '@(Url.RouteUrl("Admin_ServiceTypeCreateOrEditV2", new { fCatagoryKey = ViewBag.FCatagoryKey ?? "", Key = "SKEYPH" }))';
    var _deleteUrl = '@Url.Action("Delete", "ServiceType")';

    function escHtml(s) { if (s == null) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    function loadData() {
        $('#stTableBody').html('<tr><td colspan="7" class="text-center">Loading...</td></tr>');
        if (_countXhr) { _countXhr.abort(); _countXhr = null; }
        _totalRecords = -1;
        $('#paginationInfo').html('<small class="text-muted">Loading...</small>');
        $('#paginationContainer').html('');
        $.ajax({
            url: '/admin/servicetype-paged',
            data: { fCatagoryKey: _fCatagoryKey, searchTerm: _searchTerm, page: _page, pageSize: _pageSize },
            type: 'GET',
            success: function (res) {
                if (res.success) { renderRows(res.rows); renderPaginationHasMore(res.rows.length === _pageSize); loadCount(); }
                else { $('#stTableBody').html('<tr><td colspan="7" class="text-center text-danger">Error loading data.</td></tr>'); }
            },
            error: function () { $('#stTableBody').html('<tr><td colspan="7" class="text-center text-danger">Failed to load data.</td></tr>'); }
        });
    }

    function loadCount() {
        _countXhr = $.ajax({
            url: '/admin/servicetype-paged-count',
            data: { fCatagoryKey: _fCatagoryKey, searchTerm: _searchTerm },
            type: 'GET',
            success: function (res) { if (res.success) { _totalRecords = res.total; renderPagination(_totalRecords); } }
        });
    }

    function renderRows(rows) {
        if (!rows || rows.length === 0) { $('#stTableBody').html('<tr><td colspan="7" class="text-center">No records found.</td></tr>'); return; }
        var html = '';
        for (var i = 0; i < rows.length; i++) {
            var r = rows[i];
            var key = escHtml(r.serviceTypeKey);
            var editUrl = _editUrlTpl.replace('SKEYPH', r.serviceTypeKey);
            var img = r.image ? '<img src="' + escHtml(r.image) + '" style="max-width:50px;max-height:50px;">' : '<span>No Logo</span>';
            html += '<tr>';
            html += '<td>' + escHtml(r.serviceTypeName) + '</td>';
            html += '<td>' + escHtml(r.serviceName) + '</td>';
            html += '<td>' + escHtml(r.personQuantity) + '</td>';
            html += '<td>' + escHtml(r.size) + '</td>';
            html += '<td>' + escHtml(r.price) + '</td>';
            html += '<td>' + img + '</td>';
            html += '<td><a href="' + editUrl + '" class="btn btn-success btn-xs"><i class="fa fa-edit"></i></a> '
                + '<a href="javascript:;" class="btn btn-primary btn-xs" onclick="Delete(\'' + key + '\')"><i class="fa fa-trash"></i></a></td>';
            html += '</tr>';
        }
        $('#stTableBody').html(html);
    }

    function renderPaginationHasMore(hasMore) {
        var from = (_page - 1) * _pageSize + 1;
        var info = _totalRecords >= 0 ? '' : 'Page ' + _page + (hasMore ? '' : ' (last page)');
        $('#paginationInfo').html('<small class="text-muted">' + info + '</small>');
        var btns = '<div>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(1)"' + (_page <= 1 ? ' disabled' : '') + '>&laquo;</button>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(' + (_page - 1) + ')"' + (_page <= 1 ? ' disabled' : '') + '>&lsaquo;</button>';
        btns += '<button class="btn btn-sm btn-primary mr-1">' + _page + '</button>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(' + (_page + 1) + ')"' + (!hasMore ? ' disabled' : '') + '>&rsaquo;</button>';
        btns += '</div>'; $('#paginationContainer').html(btns);
    }

    function renderPagination(total) {
        var totalPages = Math.ceil(total / _pageSize) || 1;
        var from = total === 0 ? 0 : (_page - 1) * _pageSize + 1, to = Math.min(_page * _pageSize, total);
        $('#paginationInfo').html('<small class="text-muted">Showing ' + from + ' &ndash; ' + to + ' of ' + total + '</small>');
        var btns = '<div>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(1)"' + (_page <= 1 ? ' disabled' : '') + '>&laquo;</button>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(' + (_page - 1) + ')"' + (_page <= 1 ? ' disabled' : '') + '>&lsaquo;</button>';
        var s = Math.max(1, _page - 2), e = Math.min(totalPages, _page + 2);
        for (var p = s; p <= e; p++) btns += '<button class="btn btn-sm mr-1 ' + (p === _page ? 'btn-primary' : 'btn-outline-secondary') + '" onclick="goPage(' + p + ')">' + p + '</button>';
        btns += '<button class="btn btn-sm btn-outline-secondary mr-1" onclick="goPage(' + (_page + 1) + ')"' + (_page >= totalPages ? ' disabled' : '') + '>&rsaquo;</button>';
        btns += '<button class="btn btn-sm btn-outline-secondary" onclick="goPage(' + totalPages + ')"' + (_page >= totalPages ? ' disabled' : '') + '>&raquo;</button>';
        btns += '</div>'; $('#paginationContainer').html(btns);
    }

    window.goPage = function(p) {
        var tp = _totalRecords >= 0 ? Math.ceil(_totalRecords / _pageSize) || 1 : 99999;
        if (p < 1 || p > tp) return;
        _page = p; loadData();
    };

    $('#searchBox').on('keyup', function () {
        clearTimeout(window._st);
        window._st = setTimeout(function () { _searchTerm = $('#searchBox').val(); _page = 1; loadData(); }, 400);
    });
    $('#rowsPerPage').on('change', function () { _pageSize = parseInt($(this).val()) || 20; _page = 1; loadData(); });

    window.Delete = function(id) {
        Swal.fire({ title: 'Are you sure?', text: "You won't be able to revert this!", icon: 'question',
            showCancelButton: true, confirmButtonColor: '#3085d6', cancelButtonColor: '#d33', confirmButtonText: 'Yes, delete it!'
        }).then(function (result) {
            if (result.isConfirmed) {
                $.ajax({ url: _deleteUrl, data: { Key: id }, type: 'GET',
                    success: function () { loadData(); },
                    error: function (x, t, e) { console.log(t, e); }
                });
            }
        });
    }

    loadData();
});
</script>



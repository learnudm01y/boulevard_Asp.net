<script type="text/javascript">

    $(document).ready(function () {
        $("#IsBrand").hide()
        $("#IsCategory").hide()
        $("#IsProduct").hide()
        $("#IsService").hide()

        var productType = '@Model.IsProduct';
        var brandType = '@Model.IsBrand';
        var categoryType = '@Model.IsCategory';
        var serviceType = '@Model.IsService';

        var offerInfoId = '@Model.OfferInformationId';
        if (parseInt(offerInfoId) <= 0) {
            $("#option1").show()
            $("#option2").show()
            $("#option3").show()
            $("#option4").show()
        }
        else {
            if (brandType == "True") {
                $("#option1").show()
                $("#option2").hide()
                $("#option3").hide()
                $("#option4").hide()
            }
            if (categoryType == "True") {
                $("#option1").hide()
                $("#option2").show()
                $("#option3").hide()
                $("#option4").hide()
            }
            if (productType == "True") {
                $("#option1").hide()
                $("#option2").hide()
                $("#option3").show()
                $("#option4").hide()
            }
            if (serviceType == "True") {
                $("#option1").hide()
                $("#option2").hide()
                $("#option3").hide()
                $("#option4").show()
            }
        }



        if (productType == "True" && brandType == "False" && categoryType == "False" && serviceType == "False") {
            $("#IsBrand").hide()
            $("#IsCategory").hide()
            $("#IsProduct").show()
            $("#IsService").hide()

            $("#Brandchkhiden").val("false");
            $("#Categorychkhiden").val("false");
            $("#Productchkhiden").val("true");
            $("#Servicechkhiden").val("false");
        }
        if (productType == "False" && brandType == "True" && categoryType == "False" && serviceType == "False") {
            $("#IsBrand").show()
            $("#IsCategory").hide()
            $("#IsProduct").hide()
            $("#IsService").hide()

            $("#Brandchkhiden").val("true");
            $("#Categorychkhiden").val("false");
            $("#Productchkhiden").val("false");
            $("#Servicechkhiden").val("false");
        }
        if (productType == "False" && brandType == "False" && categoryType == "True" && serviceType == "False") {
            $("#IsBrand").hide()
            $("#IsCategory").show()
            $("#IsProduct").hide()
            $("#IsService").hide()

            $("#Brandchkhiden").val("false");
            $("#Categorychkhiden").val("true");
            $("#Productchkhiden").val("false");
            $("#Servicechkhiden").val("false");
        }

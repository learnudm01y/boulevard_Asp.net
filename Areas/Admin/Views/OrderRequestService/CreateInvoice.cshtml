<script type="text/javascript">
    function jsFunction(value) {
        $.ajax({
            async: true,
            crossDomain: true,
            type: "GET",

            url: "/admin/get/city/by/countryId?countryId=" + value,
            success: function (data) {
                console.log(data);
                //var city = data.data.cities;
                var s = '<option value="-1">Please Select a City</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].CityId + '">' + data[i].CityName + '</option>';
                }
                $("#ddCityId").html(s);
            }
        });
    }

    document.getElementById("input").addEventListener("change", function () {
        var media = URL.createObjectURL(this.files[0]);
        var video = document.getElementById("video");
        video.src = media;
        video.style.display = "block";
        video.play();
    });

        @*$(document).ready(function () {
            $("#ddCityId").val('@Model.CityId');
    });*@
</script>


<script>
    function SaveCustomer() {
        var name = $("#Name").val();
        var phoneNumber = $("#PhoneNumber").val();
        var email = $("#Email").val();
        if (name === "" || phoneNumber === "") {
            Swal.fire({
                icon: 'warning',
                title: 'Validation Error',
                text: 'Name and Phone Number are required!'
            });
            return;
        }
        $.ajax({
            url: '@Url.Action("SaveMember", "OrderRequestProduct", new { area = "Admin" })',
            type: 'POST',
            data: {
                Name: name,
                PhoneNumber: phoneNumber,
                Email: email
            },
            success: function (response) {
                if (response.success) {
                    $("#modal-lg").modal('hide');
                    $("#memberSearch").val(name);
                    $("#memberId").val(response.memberId);
                    loadMemberAddresses(response.memberId);
                    Swal.fire({
                        icon: 'success',
                        title: 'Member Added',
                        text: 'The member has been added successfully.'
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Save Failed',
                        text: response.message || 'Failed to save member. Please try again.'
                    });
                }
            },
            error: function () {
                Swal.fire({
                    icon: 'error',
                    title: 'Server Error',
                    text: 'An error occurred while saving. Please try later.'
                });
            }
        });
    }
</script>




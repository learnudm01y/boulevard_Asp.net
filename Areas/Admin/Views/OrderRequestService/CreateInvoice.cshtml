     function loadMemberAddresses(memberId) {
    $.ajax({
        url: '@Url.Action("GetMemberAddresses", "OrderRequestProduct", new { area = "Admin" })',
        type: 'GET',
        data: { memberId },
        success: function (addresses) {
            var html = "";

            html += "<div class='d-flex justify-content-between align-items-center mb-2'>";
            html += "<h5>Select an Address</h5>";
            html += "<button type='button' class='btn btn-sm btn-primary' onclick='openAddAddressPopup()'>Add Address</button>";
            html += "</div>";

            if (addresses.length > 0) {
                html += "<div class='list-group'>";
                $.each(addresses, function (index, address) {
                    var addressText = `${address.AddressLine1}, ${address.AddressLine2}, ${address.NearByAddress}`;
                    html += `
                        <label class='list-group-item'>
                            <input type='radio' name='addressRadio' value='${address.MemberAddressId}' ${index === 0 ? "checked" : ""} />
                            ${addressText}
                            <button type='button' class='btn btn-sm btn-link' onclick='editAddress(${JSON.stringify(address)})'>Edit</button>
                        </label>`;
                });
                html += "</div>";

                // Set first address as selected
                $("#MemberAddressId").val(addresses[0].MemberAddressId);
            } else {
                html += "<p class='text-muted'>No addresses found for this member.</p>";
            }

            $("#addressContainer").html(html);

            // Radio button change handler
            $("input[name='addressRadio']").on('change', function () {
                $("#MemberAddressId").val($(this).val());
            });
        },
        error: function () {
            $("#addressContainer").html("<p class='text-danger'>Failed to load addresses.</p>");
        }
    });
}


function openAddAddressPopup() {
    $("#addressForm")[0].reset();
    $("#AddressId").val(0);
    $("#MemberId").val($("#memberId").val());
    $("#addressModal").modal("show");
}

function editAddress(address) {
    $("#AddressId").val(address.MemberAddressId);
    $("#MemberId").val(address.MemberId);
    //$("input[name='CountryId']").val(address.CountryId);
    //$("input[name='CityId']").val(address.CityId);
    $("input[name='AddressLine1']").val(address.AddressLine1);
    $("input[name='AddressLine2']").val(address.AddressLine2);
    $("input[name='NearByAddress']").val(address.NearByAddress);
    $("#ddCountryId").val(address.CountryId).trigger('change');

    // After Country dropdown changes and cities are loaded,
    // set selected CityId
    setTimeout(function () {
        $("#ddCityId").val(address.CityId);
    }, 500); // Delay ensures cities are loaded
    $("#addressModal").modal("show");
}


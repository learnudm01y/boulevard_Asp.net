<script>
    function loadAutocomplete(input) {
        var fcId = @Html.Raw(Json.Encode(Model.FeatureCategory.FeatureCategoryId));

        $(input).autocomplete({
            source: function (request, response) {
                $.ajax({
                    url: '@Url.Action("SearchProduct", "OrderRequestProduct", new { area = "Admin" })',
                    type: 'GET',
                    dataType: 'json',
                    data: {
                        term: request.term,
                        fcId: fcId
                    },
                    success: function (data) {
                        response($.map(data, function (item) {
                            return {
                                label: item.ProductName,
                                value: item.ProductName,
                                id: item.ProductId,
                                stock: item.StockQuantity,
                                price: item.ProductPrice,
                                image: item.ProductImage // image URL or path
                            };
                        }));
                    }
                });
            },
            select: function (event, ui) {
                $(input).val(ui.item.label);

                var row = $(input).closest("tr");
                row.find("input[type='hidden'][name$='.ProductId']").val(ui.item.id);
                row.find("input[name$='.Product.StockQuantity']").val(ui.item.stock);
                row.find("input[name$='.GrossPrice']").val(ui.item.price);

                return false;
            },
            minLength: 2
        })
        .autocomplete("instance")._renderItem = function (ul, item) {
            return $("<li>")
                .append(`
                    <div style="display: flex; align-items: center; padding: 5px;">
                        <img src="${item.image}" alt="Product" style="width: 40px; height: 40px; object-fit: cover; margin-right: 10px; border: 1px solid #ccc;">
                        <div>
                            <div><strong>${item.label}</strong></div>
                            <div style="font-size: 12px; color: gray;">Price: ${item.price}, Stock: ${item.stock}</div>
                        </div>
                    </div>
                `)
                .appendTo(ul);
        };
    }


    function addGrade() {
        var body = jQuery("#tblSalesInvoice");
        var count = body.find("tr").length;
        var tr = body.find("tr").first().clone();
        var inputs = tr.find(":input");
        inputs.val("");
        jQuery.each(inputs, function (i, item) {
            jQuery("#cnt").val(count);
            if (i == 3 | i == 4 || i == 5 || i == 6 || i == 7) {
                jQuery(item).prop("name", jQuery(item).prop("name").replace(/\[[0-9]+\]/, "[" + count + "]"));
            }
            else {
                jQuery(item).prop("name", jQuery(item).prop("name").replace(/\[[0-9]+\]/g, "[" + count + "]"));
            }
        });
        body.append(tr);
        GrandTotalCalculation();
    }

    function removeGrade(cntrl) {
        var body = jQuery("#tblSalesInvoice");
        if (body.find("tr").length === 1)
            return;

        jQuery(cntrl).parent().parent().remove();

        var trs = body.find("tr");

        jQuery.each(trs, function (ix, tr) {
            jQuery.each(jQuery(tr).find("input"), function (i, item) {
                jQuery(item).prop("name", jQuery(item).prop("name").replace(/\[[0-9]+\]/g, "[" + ix + "]"));
            });
        });
        GrandTotalCalculation();

    }

    $(document).ready(function () {
        $("#myInput").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#tblSalesInvoice tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    });

</script>

<script>
    function calculateQty_price(cntrl) {
        var name = cntrl.getAttribute('name');
        var baseName = name.split('.')[0];

        var qtyName = baseName + ".Quantity";
        var stockQtyName = baseName + ".Product.StockQuantity";
        var grossPriceName = baseName + ".GrossPrice";
        var discountAmountName = baseName + ".DiscountAmount";
        var totalGrossPriceName = baseName + ".TotalGrossPrice";

        // Raw input
        var qtyRaw = $("input[name='" + qtyName + "']").val();

        // Disallow any non-numeric input (including +, -, letters)
        if (!/^\d*\.?\d*$/.test(qtyRaw)) {
            $("input[name='" + qtyName + "']").val(0);

            Swal.fire({
                icon: 'warning',
                title: 'Invalid Input',
                text: 'Only numeric values are allowed for quantity!',
                confirmButtonColor: '#3085d6'
            });
            return;
        }

        // Convert to float
        var qty = parseFloat(qtyRaw) || 0;
        var stockQty = parseFloat($("input[name='" + stockQtyName + "']").val()) || 0;
        var grossPrice = parseFloat($("input[name='" + grossPriceName + "']").val()) || 0;
        var discount = parseFloat($("input[name='" + discountAmountName + "']").val()) || 0;

        // Check for negative or 0 quantity
        if (qty <= 0) {
            $("input[name='" + qtyName + "']").val(0);
            $("input[name='" + totalGrossPriceName + "']").val(0);
            Swal.fire({
                icon: 'warning',
                title: 'Invalid Quantity',
                text: 'Quantity must be greater than 0!',
                confirmButtonColor: '#3085d6'
            });
            return;
        }

        // Check if quantity exceeds stock
        if (qty > stockQty) {
            $("input[name='" + qtyName + "']").val(0);
            $("input[name='" + totalGrossPriceName + "']").val(0);
            Swal.fire({
                icon: 'warning',
                title: 'Stock Exceeded',
                text: 'Quantity cannot exceed available stock!',
                confirmButtonColor: '#3085d6'
            });
            return;
        }

        // Valid input — calculate total
        var total = (qty * grossPrice) - discount;
        $("input[name='" + totalGrossPriceName + "']").val(total.toFixed(2));
        AllSum();
    }

    function AllSum() {
        let counter = 0;
        var totalUnitPrice = 0;
        var totalQty = 0;
        var table = jQuery("#tblSalesInvoice");
        table.find('tr').each(function () {
            var $tds = $(this).find('td');
            var inputs = $tds.find(":input");

            totalQty = parseFloat(inputs[4].value);
            if (isNaN(totalQty))
                totalQty += totalQty;

            totalUnitPrice = parseFloat(inputs[7].value);
            if (isNaN(totalUnitPrice))
                totalUnitPrice += totalUnitPrice;
        });

        $("#TotalQty").val(totalQty.toFixed(2))
        $("#TotalUnit").val(totalUnitPrice.toFixed(2))
        GrandTotalCalculation();
    }

    function GrandTotalCalculation() {
        var count = 0;

        var totalUnitPrice = parseFloat(0);
        var unitPrice = parseFloat(0);


        let counter = 0;
        var table = jQuery("#tblSalesInvoice");
        table.find('tr').each(function () {
            var $tds = $(this).find('td');
            var inputs = $tds.find(":input");

            counter++;
            $tds[0].innerHTML = counter;


            unitPrice = parseFloat(inputs[7].value);
            if (isNaN(unitPrice))
                unitPrice = 0;
            totalUnitPrice += parseFloat(unitPrice);

        });

        if (parseFloat($("#DeliveryCharge").val()) > 0) {
            totalUnitPrice = totalUnitPrice + parseFloat($("#DeliveryCharge").val());
        }

        $("#SubTotalAmount").val(totalUnitPrice.toFixed(2));
    }

</script>



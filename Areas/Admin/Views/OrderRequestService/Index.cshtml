@model IEnumerable<Boulevard.Models.OrderRequestService>
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<!-- Container fluid  -->
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- Breadcrumb -->
        @if (ViewBag.FCatagoryKey != null)
        {
            <div class="row page-titles">
                <div class="col-md-5 col-12 align-self-center">
                    <h3 class="text-themecolor mb-0">Order Request @ViewBag.FCatagoryName Service</h3>
                </div>
                <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                        <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                        <li class="breadcrumb-item active">Order Request @ViewBag.FCatagoryName Service</li>
                    </ol>
                </div>
            </div>
        }
        else
        {
            <div class="row page-titles">
                <div class="col-md-5 col-12 align-self-center">
                    <h3 class="text-themecolor mb-0">Order Request Service</h3>
                </div>
                <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                        <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_dashboard")">Home</a></li>
                        <li class="breadcrumb-item active">Order Request Service</li>
                    </ol>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body">

                <div class="row align-items-center mb-3">
                    <div class="col-sm-8">
                        @if (ViewBag.FCatagoryKey != null)
                        {
                            <h4 class="card-title">Order Request @ViewBag.FCatagoryName Service</h4>
                        }
                        else
                        {
                            <h4 class="card-title">Order Request Service</h4>
                        }
                    </div>
                </div>

                <!-- Filters row -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="font-weight-bold">Booking Status</label>
                        <select id="statusFilter" class="form-control">
                            <option value="">All Statuses</option>
                            @if (ViewBag.BookingStatuses != null)
                            {
                                foreach (var st in ViewBag.BookingStatuses)
                                {
                                    <option value="@st">@st</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="font-weight-bold">Rows per page</label>
                        <select id="pageSizeSelect" class="form-control">
                            <option value="10">10</option>
                            <option value="20" selected>20</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                            <option value="200">200</option>
                            <option value="500">500</option>
                        </select>
                    </div>
                    <div class="col-md-7 align-self-end">
                        <span id="resultsInfo" class="text-muted small"></span>
                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive" style="min-height:420px">
                    <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                        <thead>
                            <tr>
                                <th>Booking ID</th>
                                <th>Member Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Extra Charge</th>
                                <th>Total Price</th>
                                <th>Booking Date</th>
                                <th>Booking Time</th>
                                <th>Status</th>
                                <th>Options</th>
                            </tr>
                        </thead>
                        <tbody id="servicesTableBody">
                            <tr>
                                <td colspan="10" class="text-center">
                                    <i class="fa fa-spinner fa-spin"></i> Loading...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="row mt-3">
                    <div class="col-sm-5">
                        <span id="paginationInfo" class="text-muted small"></span>
                    </div>
                    <div class="col-sm-7">
                        <nav aria-label="Services pagination">
                            <ul class="pagination justify-content-end mb-0" id="paginationControls"></ul>
                        </nav>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var _currentPage = 1;
    var _pageSize = 20;
    var _bookingStatus = '';
    var _fCatagoryKey = '@(ViewBag.FCatagoryKey ?? string.Empty)';
    var _totalRows = 0;
    var _countXhr = null;

    // First page pre-loaded server-side: table renders without any AJAX wait.
    // Only the total COUNT is fetched asynchronously after the table appears.
    var _initialRows    = @Html.Raw(ViewBag.InitialRows ?? "null");
    var _initialHasMore = @(ViewBag.InitialHasMore != null && ((bool)ViewBag.InitialHasMore) ? "true" : "false");

    // ── Step 1: fetch rows only (no COUNT) ──────────────────────
    function loadOrders() {
        $('#servicesTableBody').html(
            '<tr><td colspan="10" class="text-center py-3">' +
            '<i class="fa fa-spinner fa-spin mr-1"></i> Loading...</td></tr>'
        );
        $('#paginationInfo').text('');
        $('#paginationControls').html('');
        _totalRows = -1;

        if (_countXhr) { _countXhr.abort(); _countXhr = null; }

        $.ajax({
            type: 'POST',
            url: '/admin/order-service-paged',
            data: {
                fCatagoryKey: _fCatagoryKey,
                bookingStatus: _bookingStatus,
                page: _currentPage,
                pageSize: _pageSize
            },
            success: function (res) {
                if (!res.success) {
                    $('#servicesTableBody').html(
                        '<tr><td colspan="10" class="text-center text-danger">Failed to load data.</td></tr>'
                    );
                    return;
                }
                renderRows(res.rows);
                renderPaginationHasMore(res.rows && res.rows.length === _pageSize);
                loadCount();
            },
            error: function () {
                $('#servicesTableBody').html(
                    '<tr><td colspan="10" class="text-center text-danger">Error loading data. Please try again.</td></tr>'
                );
            }
        });
    }

    // ── Step 2: fetch total count after rows are rendered ────────
    function loadCount() {
        $('#paginationInfo').html('<span class="text-muted">Counting records&hellip;</span>');
        _countXhr = $.ajax({
            type: 'POST',
            url: '/admin/order-service-paged-count',
            data: {
                fCatagoryKey: _fCatagoryKey,
                bookingStatus: _bookingStatus
            },
            success: function (res) {
                _countXhr = null;
                if (!res.success) return;
                _totalRows = res.total;
                var start = (_currentPage - 1) * _pageSize + 1;
                var end   = Math.min(_currentPage * _pageSize, _totalRows);
                $('#paginationInfo').text('Showing ' + start + ' to ' + end + ' of ' + _totalRows + ' entries');
                renderPagination(_totalRows);
            },
            error: function () { _countXhr = null; }
        });
    }

    function renderRows(rows) {
        if (!rows || rows.length === 0) {
            $('#servicesTableBody').html(
                '<tr><td colspan="10" class="text-center">No records found.</td></tr>'
            );
            $('#paginationInfo').text('');
            return;
        }

        var html = '';
        $.each(rows, function (i, row) {
            var st = row.BookingStatus || '';
            var statusClass = (st === 'Cancelled' || st === 'Rejected') ? 'btn-dark-danger' : 'btn-success';
            html += '<tr>';
            html += '<td>' + escHtml(row.BookingId) + '</td>';
            html += '<td>' + escHtml(row.MemberName) + '</td>';
            html += '<td>' + escHtml(row.Email) + '</td>';
            html += '<td>' + escHtml(row.PhoneNo) + '</td>';
            html += '<td>' + escHtml(row.ExtraCharge) + '</td>';
            html += '<td>' + escHtml(row.TotalPrice) + '</td>';
            html += '<td>' + escHtml(row.BookingDate) + '</td>';
            html += '<td>' + escHtml(row.BookingTime) + '</td>';
            html += '<td><button class="btn ' + statusClass + ' btn-xs"><span>' + escHtml(st) + '</span></button></td>';
            html += '<td>';
            html += '<a href="/admin/order-service-details/' + row.OrderRequestServiceId + '" class="btn btn-success btn-xs" title="Details"><i class="fa fa-eye"></i></a> ';
            html += '<a href="/admin/order-service-invoice/' + row.OrderRequestServiceId + '" class="btn btn-primary btn-xs" title="Invoice"><i class="fas fa-print"></i></a> ';
            html += '<a href="/admin/order-service-delivaryslip/' + row.OrderRequestServiceId + '" class="btn btn-success btn-xs" title="Delivery Slip"><i class="fas fa-print"></i></a>';
            html += '</td>';
            html += '</tr>';
        });

        $('#servicesTableBody').html(html);
    }

    function renderPaginationHasMore(hasMore) {
        var html = '';
        html += '<li class="page-item' + (_currentPage <= 1 ? ' disabled' : '') + '">';
        html += '<a class="page-link" href="#" data-page="' + (_currentPage - 1) + '">&laquo; Prev</a></li>';
        html += '<li class="page-item active"><span class="page-link">' + _currentPage + '</span></li>';
        if (hasMore) {
            html += '<li class="page-item">';
            html += '<a class="page-link" href="#" data-page="' + (_currentPage + 1) + '">Next &raquo;</a></li>';
        }
        $('#paginationControls').html(html);
    }

    function renderPagination(total) {
        var totalPages = Math.ceil(total / _pageSize);
        if (totalPages <= 1) {
            $('#paginationControls').html('');
            return;
        }

        var html = '';
        html += '<li class="page-item' + (_currentPage <= 1 ? ' disabled' : '') + '">';
        html += '<a class="page-link" href="#" data-page="' + (_currentPage - 1) + '">&laquo;</a></li>';

        var startPage = Math.max(1, _currentPage - 2);
        var endPage   = Math.min(totalPages, _currentPage + 2);

        if (startPage > 1) {
            html += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';
            if (startPage > 2) html += '<li class="page-item disabled"><span class="page-link">&hellip;</span></li>';
        }

        for (var p = startPage; p <= endPage; p++) {
            html += '<li class="page-item' + (p === _currentPage ? ' active' : '') + '">';
            html += '<a class="page-link" href="#" data-page="' + p + '">' + p + '</a></li>';
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1) html += '<li class="page-item disabled"><span class="page-link">&hellip;</span></li>';
            html += '<li class="page-item"><a class="page-link" href="#" data-page="' + totalPages + '">' + totalPages + '</a></li>';
        }

        html += '<li class="page-item' + (_currentPage >= totalPages ? ' disabled' : '') + '">';
        html += '<a class="page-link" href="#" data-page="' + (_currentPage + 1) + '">&raquo;</a></li>';

        $('#paginationControls').html(html);
    }

    function escHtml(str) {
        if (str == null) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    $(document).ready(function () {
        // Use server-pre-loaded first page — no AJAX round-trip needed.
        if (_initialRows && _initialRows.length > 0) {
            renderRows(_initialRows);
            renderPaginationHasMore(_initialHasMore);
            loadCount();
        } else {
            loadOrders();
        }

        $('#statusFilter').on('change', function () {
            _bookingStatus = $(this).val();
            _currentPage = 1;
            loadOrders();
        });

        $('#pageSizeSelect').on('change', function () {
            _pageSize = parseInt($(this).val());
            _currentPage = 1;
            loadOrders();
        });

        $(document).on('click', '#paginationControls .page-link', function (e) {
            e.preventDefault();
            var page = parseInt($(this).data('page'));
            if (isNaN(page) || page < 1) return;
            if (_totalRows > 0) {
                var totalPages = Math.ceil(_totalRows / _pageSize);
                if (page > totalPages) return;
            }
            _currentPage = page;
            loadOrders();
        });
    });
</script>


@{
    ViewBag.Title = "Laundry Service Details";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    table, th, td {
        border: 1px solid black;
        border-collapse: collapse;
        text-align: center;
    }

    table {
        width: 500px;
    }
</style>
<div class="page-wrapper">
    <div class="container-fluid">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="row page-titles">
            <div class="col-md-5 col-12 align-self-center">
                <h3 class="text-themecolor mb-0">Laundry Service Details</h3>
            </div>
            <div class="col-md-7 col-12 align-self-center d-none d-md-block">
                <ol class="breadcrumb mb-0 p-0 bg-transparent float-right">
                    <li class="breadcrumb-item active"><a href="@Url.RouteUrl("Admin_Order_Request_Service_List")">Order Service</a></li>
                    <li class="breadcrumb-item active">Laundry Service Details</li>
                </ol>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!--order list-->
        <form>
            <div class="card">
                <div class="card-header">
                    Laundry Service Details
                </div>
                <div class="card-body">
                    <div class="row" style="font-size:20px">

                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Booking Id : </label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Booking Date : @DateTime.Now.ToString("dd/MM/yyyy")</label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Booking Time : @DateTime.Now.ToShortTimeString()</label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Booking Member Type : Regular</label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Member Name : </label>
                            </div>
                        </div>

                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Phone No : </label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Email : </label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>
                                    Laundry Company Name :
                                </label>
                            </div>
                        </div>

                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Extra Charge : </label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Gross Price : </label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Total Price : </label>
                            </div>
                        </div>
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">
                                <label>Booking Status : </label>
                            </div>
                        </div>
                    </div>
                    <br />
                    <br />
                    <br />

                    <div class="row">
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group float-xl-right">
                                <h1>Laundry Service Details</h1>
                            </div>
                        </div>
                        <div class="table-responsive">

                            <table id="zero_config" class="table table-striped table-bordered" cellspacing="0" width="100%">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>Laundry Service Type</th>
                                        <th>Image</th>
                                        <th>Description</th>
                                        <th>Price</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    <tr>
                                        <td></td>
                                        <td>Wash & Fold</td>
                                        <td><img src="~/Areas/Admin/Content/assets/images/default.jpg" style="max-width:50px;max-height:50px;"></td>
                                        <td>Standard wash and fold service</td>
                                        <td>50 AED</td>
                                    </tr>

                                </tbody>
                            </table>

                        </div>
                    </div>
                </div>
            </div>
        </form>
        <!-- ============================================================== -->
    </div>
</div>
